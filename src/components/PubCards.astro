---
// Nikola-style card grid for publications / datasets / patents,
// but each card carries proper bibliographic content:
//   thumbnail → title → authors (with ORCID iD icons, * for equal
//   contribution) → venue, year · note → optional link.
// (Whole-card link avoided so author iD <a>s don't nest inside an <a>.)
const { items = [] } = Astro.props;
const hasEq = items.some((it) => (it.authors || []).some((a) => a.eq));
const ORCID_SVG =
  '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>';
---
<div class="pub-grid">
  {items.map((it, i) => {
    const ext = it.href && it.href.startsWith('http');
    // ImageMetadata (imported asset) → use .src; plain string → use as-is.
    const srcOf = (m) => (typeof m === 'string' ? m : (m && m.src) || '');
    const pages = (Array.isArray(it.pages) ? it.pages : []).filter(Boolean);
    const hasImg = pages.length > 0 || !!it.img;
    const thumbCls = `pub-thumb${hasImg ? ' pub-thumb--doc' : ''}`;
    // Real images keep their natural aspect ratio (no letterbox); placeholders stay 3/4.
    const lead = pages.length > 0 ? pages[0] : it.img;
    const ar = lead && lead.width && lead.height ? ` aspect-ratio:${lead.width}/${lead.height};` : '';
    const thumbStyle = `--h:${(i * 53 + 28) % 360};${ar}`;
    const inner = pages.length > 0 ? (
      <div class="pub-pages" data-flip>
        {pages.map((p, k) => (
          <img class={k === 0 ? 'is-active' : ''} src={srcOf(p)} alt={`${it.title} — page ${k + 1}`} loading="lazy" />
        ))}
        {pages.length > 1 && <span class="pub-pages-count"><b>1</b>/{pages.length}</span>}
      </div>
    ) : it.img ? (
      <img src={srcOf(it.img)} alt={it.title} loading="lazy" />
    ) : null;
    return (
      <article class="pub-card reveal">
        {it.href ? (
          <a class={thumbCls} href={it.href} style={thumbStyle} {...(ext ? { target: '_blank', rel: 'noopener noreferrer' } : {})} aria-label={it.title}>
            {inner}
          </a>
        ) : (
          <div class={thumbCls} style={thumbStyle}>
            {inner}
          </div>
        )}
        <h3 class="pub-title">{it.title}</h3>
        <p class="pub-authors">
          {it.authors.map((a, j) => (
            <>
              <span class="pub-author"
                >{a.name}{a.eq && <sup class="bib-eq">*</sup>}{a.orcid ? (
                  <a class="bib-id" href={a.orcid} target="_blank" rel="noopener noreferrer" aria-label={`${a.name} — ORCID`} set:html={ORCID_SVG} />
                ) : (
                  <span class="bib-id bib-id--none" title="ORCID not listed" aria-hidden="true" set:html={ORCID_SVG} />
                )}</span
              >{j < it.authors.length - 1 ? <span>, </span> : ''}
            </>
          ))}
        </p>
        <p class="pub-meta"><span class="pub-venue">{it.venue}</span>{it.year ? `, ${it.year}` : ''}{it.note ? ` · ${it.note}` : ''}</p>
        {it.href && (
          <a class="pub-link" href={it.href} {...(ext ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
            {it.cta || (ext ? 'Visit' : 'Details')}
            <span class="pub-arrow">{ext ? '↗' : '→'}</span>
          </a>
        )}
      </article>
    );
  })}
</div>
{hasEq && <p class="bib-foot" data-en="* Equal contribution" data-ko="* 공동 기여">* Equal contribution</p>}

<style>
  /* cols-1 · lg(1024):2 · xl(1280):3 — gap-16 mobile, sm(640):gap-8 */
  .pub-grid { display: grid; grid-template-columns: 1fr; gap: 4rem; max-width: 980px; }
  @media (min-width: 640px) { .pub-grid { gap: 2rem; } }
  @media (min-width: 1024px) { .pub-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1280px) { .pub-grid { grid-template-columns: repeat(3, 1fr); } }

  .pub-card { display: flex; flex-direction: column; }
  .pub-thumb {
    display: block;
    aspect-ratio: 3 / 4;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 1.1rem;
    background: linear-gradient(150deg, hsl(var(--h) 30% 90%) 0%, hsl(calc(var(--h) + 35) 28% 80%) 100%);
    box-shadow: 0 4px 18px rgba(var(--fg-rgb), 0.14);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  html.dark .pub-thumb { background: linear-gradient(150deg, hsl(var(--h) 16% 24%) 0%, hsl(calc(var(--h) + 35) 18% 17%) 100%); }
  .pub-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  a.pub-thumb:hover { transform: translateY(-4px); box-shadow: 0 22px 52px rgba(var(--fg-rgb), 0.26); }

  /* Real document/figure images: show the whole page on a neutral backdrop. */
  .pub-thumb--doc { background: var(--surface); }
  .pub-thumb--doc > img { object-fit: contain; }

  /* Stacked pages — hover flips through them one at a time. */
  .pub-pages { position: relative; width: 100%; height: 100%; }
  .pub-pages img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; opacity: 0; transition: opacity 0.4s ease; }
  .pub-pages img.is-active { opacity: 1; }
  .pub-pages-count {
    position: absolute; right: 0.55rem; bottom: 0.55rem;
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.02em;
    color: #fff; background: rgba(0, 0, 0, 0.55); backdrop-filter: blur(4px);
    padding: 0.15rem 0.45rem; border-radius: 999px;
    opacity: 0; transition: opacity 0.25s ease; pointer-events: none;
  }
  .pub-thumb:hover .pub-pages-count { opacity: 1; }
  @media (prefers-reduced-motion: reduce) { .pub-pages img { transition: none; } }

  .pub-title { font-size: 1.08rem; font-weight: 700; line-height: 1.4; letter-spacing: -0.01em; margin-bottom: 0.5rem; }
  .pub-authors { font-size: 0.9rem; line-height: 1.6; margin-bottom: 0.3rem; }
  .pub-author { white-space: nowrap; }
  .bib-eq { color: var(--muted); font-weight: 600; }
  .bib-id { display: inline-flex; align-items: center; vertical-align: middle; margin: 0 0.1rem 0 0.16rem; }
  .bib-id svg { width: 0.9em; height: 0.9em; fill: #a6ce39; display: block; }
  .bib-id--none svg { fill: rgba(var(--fg-rgb), 0.25); }
  .pub-meta { font-size: 0.86rem; color: var(--muted); }
  .pub-venue { font-style: italic; }
  .pub-link { margin-top: 0.7rem; font-size: 0.84rem; font-weight: 600; color: var(--link); opacity: 0.92; text-decoration: none; }
  .pub-link:hover { opacity: 1; text-decoration: underline; text-underline-offset: 3px; }
  .pub-arrow { color: var(--link); font-weight: 700; margin-left: 0.18rem; display: inline-block; transition: transform 0.2s ease; }
  .pub-link:hover .pub-arrow { transform: translate(2px, -2px); }
  .bib-foot { margin-top: 1.4rem; font-size: 0.82rem; color: var(--muted); }
</style>

<script>
  // Flip through a paper's pages while the thumbnail is hovered.
  const SPEED = 650; // ms between pages
  document.querySelectorAll('.pub-pages[data-flip]').forEach((el) => {
    const imgs = Array.from(el.querySelectorAll('img'));
    if (imgs.length < 2) return;
    const counter = el.querySelector('.pub-pages-count b');
    const thumb = el.closest('.pub-thumb');
    let idx = 0;
    let timer = null;
    const show = (n) => {
      imgs[idx].classList.remove('is-active');
      idx = (n + imgs.length) % imgs.length;
      imgs[idx].classList.add('is-active');
      if (counter) counter.textContent = String(idx + 1);
    };
    const start = () => { if (!timer) timer = window.setInterval(() => show(idx + 1), SPEED); };
    const stop = () => { clearInterval(timer); timer = null; show(0); };
    thumb.addEventListener('mouseenter', start);
    thumb.addEventListener('mouseleave', stop);
    // Touch / no-hover devices: tap advances one page (only when not a link).
    if (thumb.tagName !== 'A') {
      thumb.addEventListener('click', () => show(idx + 1));
    }
  });
</script>
