---
// Floating "Contact and links" dock — shared across the nav (sub-)pages so it
// appears everywhere the top nav does. The home page has its own inline copy.
// The email address is assembled in the browser, never written to page source.
const socials = [
  { key: 'github', label: 'GitHub', url: 'https://github.com/alwaysY0ung' },
  { key: 'scholar', label: 'Google Scholar', url: 'https://scholar.google.com/citations?user=O9-EG6oAAAAJ' },
  { key: 'orcid', label: 'ORCID', url: 'https://orcid.org/0009-0006-8907-6504' },
  { key: 'linkedin', label: 'LinkedIn', url: 'https://www.linkedin.com/in/chaeyoung-lee-bb934b34a/' },
];
const ICONS = {
  github:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>',
  scholar:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>',
  orcid:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>',
  linkedin:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>',
};
---
<div class="dock-wrap">
  <div class="contact-pop" id="contactPop" role="dialog" aria-label="Contact email" aria-hidden="true">
    <div class="contact-win">
      <div class="contact-head">
        <span class="win-dot win-dot--r"></span>
        <span class="win-dot win-dot--y"></span>
        <span class="win-dot win-dot--g"></span>
        <span class="win-title">contact — email</span>
      </div>
      <div class="contact-body">
        <p class="contact-cmd"><span class="term-prompt">~$ </span>echo&nbsp;$EMAIL</p>
        <div class="contact-row">
          <a class="email-reveal" id="emailReveal" href="#" rel="noopener">…</a>
          <button class="email-copy" id="emailCopy" type="button" aria-label="Copy email" data-en="copy" data-ko="복사">copy</button>
        </div>
        <p class="contact-foot" data-en="Tip: copy works on any device. The address is assembled in your browser, never written in the page source." data-ko="팁: 복사는 모든 기기에서 됩니다. 주소는 브라우저에서 조합되며 페이지 소스에는 적혀 있지 않습니다.">Tip: copy works on any device. The address is assembled in your browser, never written in the page source.</p>
      </div>
    </div>
  </div>
  <div class="dock" aria-label="Contact and links">
    <button class="dock-toggle" id="dockToggle" type="button" aria-expanded="false" aria-controls="contactPop">
      <span class="dock-dot"></span>Contact in email<span class="dock-caret">▴</span>
    </button>
    <span class="dock-sep" aria-hidden="true"></span>
    {socials.map((s) =>
      s.url ? (
        <a class="dock-item" href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.label} title={s.label}>
          <Fragment set:html={ICONS[s.key]} />
        </a>
      ) : (
        <span class="dock-item dock-item--todo" role="img" aria-label={s.label} title={`${s.label} (URL 준비 중)`}>
          <Fragment set:html={ICONS[s.key]} />
        </span>
      )
    )}
    <span class="dock-sep" aria-hidden="true"></span>
    <button class="dock-item dock-top" id="dockTop" type="button" aria-label="맨 위로" title="맨 위로">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </button>
  </div>
</div>

<style>
  .dock-wrap { position: fixed; left: 50%; bottom: 1.5rem; transform: translateX(-50%); z-index: 50; }
  .dock {
    --card-padding: 0.3rem;
    --card-radius: 16px;
    display: flex; align-items: center; gap: 0.2rem; width: auto;
    padding: var(--card-padding); background: var(--block); border-radius: var(--card-radius);
    box-shadow: 0 10px 30px rgba(var(--fg-rgb), 0.18);
  }
  .dock-toggle {
    display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.45rem 0.85rem;
    background: transparent; border: none; cursor: pointer; color: rgba(var(--bg-rgb), 0.9);
    font-family: inherit; font-size: 0.8rem; font-weight: 600; white-space: nowrap;
    border-radius: calc(var(--card-radius) - var(--card-padding)); transition: background 0.2s ease;
  }
  .dock-toggle:hover { background: rgba(var(--bg-rgb), 0.12); }
  .dock-caret { font-size: 0.62rem; opacity: 0.7; transition: transform 0.28s ease; }
  .dock-toggle[aria-expanded='true'] .dock-caret { transform: rotate(180deg); }
  .dock-dot { width: 7px; height: 7px; border-radius: 50%; background: #34d399; animation: dock-pulse 2s ease-out infinite; }
  @keyframes dock-pulse {
    0% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.5); }
    70% { box-shadow: 0 0 0 7px rgba(52, 211, 153, 0); }
    100% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0); }
  }
  .dock-sep { width: 1px; height: 18px; margin: 0 0.15rem; background: rgba(var(--bg-rgb), 0.18); }
  .dock-item {
    display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px;
    border-radius: calc(var(--card-radius) - var(--card-padding)); color: var(--bg); text-decoration: none;
    background: transparent; transition: background 0.2s ease, transform 0.15s ease;
  }
  .dock-item svg { width: 16px; height: 16px; display: block; }
  .dock-item:hover { background: rgba(var(--bg-rgb), 0.14); transform: translateY(-1px); }
  .dock-item--todo { opacity: 0.4; cursor: default; }
  .dock-item--todo:hover { background: transparent; transform: none; }
  .dock-top { cursor: pointer; }
  .dock-top svg { fill: none; stroke: currentColor; }

  /* contact popover — a macOS window that minimizes to / restores from the dock */
  .contact-pop {
    position: absolute; left: 50%; bottom: calc(100% + 1.6rem); width: min(440px, 92vw);
    opacity: 0; visibility: hidden;
    transform: translateX(-50%) translateY(30px) scale(0.55); transform-origin: bottom center;
    transition: opacity 0.24s ease, transform 0.36s cubic-bezier(0.2, 0.9, 0.25, 1.12), visibility 0s linear 0.36s;
  }
  .contact-pop.open {
    opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0) scale(1);
    transition: opacity 0.2s ease, transform 0.36s cubic-bezier(0.2, 0.9, 0.25, 1.12), visibility 0s;
  }
  .contact-win { background: var(--bg); border: 1px solid rgba(var(--fg-rgb), 0.14); border-radius: 12px; box-shadow: 0 24px 60px rgba(0, 0, 0, 0.38); overflow: hidden; }
  .contact-head { display: flex; align-items: center; gap: 0.45rem; padding: 0.6rem 0.85rem; background: rgba(var(--fg-rgb), 0.04); border-bottom: 1px solid rgba(var(--fg-rgb), 0.08); }
  .win-dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
  .win-dot--r { background: #ff5f57; } .win-dot--y { background: #febc2e; } .win-dot--g { background: #28c840; }
  .win-title { margin-left: 0.4rem; font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.74rem; color: var(--muted); }
  .contact-body { padding: 1.45rem 1.55rem 1.55rem; font-family: ui-monospace, 'SF Mono', Menlo, 'Consolas', monospace; }
  .contact-cmd { font-size: 0.84rem; color: rgba(var(--fg-rgb), 0.5); margin-bottom: 0.7rem; }
  .contact-cmd .term-prompt { color: rgba(var(--fg-rgb), 0.38); }
  .contact-row { display: flex; align-items: center; gap: 0.7rem; }
  .email-reveal { font-size: 1.06rem; font-weight: 600; color: var(--fg); text-decoration: none; word-break: break-all; }
  a.email-reveal:hover { text-decoration: underline; }
  .email-copy { margin-left: auto; flex: none; font-family: inherit; font-size: 0.72rem; padding: 0.32rem 0.62rem; border-radius: 6px; border: 1px solid rgba(var(--fg-rgb), 0.18); background: var(--block); color: var(--bg); cursor: pointer; transition: opacity 0.2s ease; }
  .email-copy:hover { opacity: 0.85; }
  .contact-foot { margin-top: 0.85rem; font-family: 'Inter', system-ui, sans-serif; font-size: 0.76rem; color: var(--muted); line-height: 1.55; }

  @media (prefers-reduced-motion: reduce) {
    .dock-dot { animation: none; }
    .contact-pop { transition: opacity 0.15s ease, visibility 0s; transform: translateX(-50%); }
    .contact-pop.open { transform: translateX(-50%); }
  }
</style>

<script>
  (function () {
    var top = document.getElementById('dockTop');
    if (top) top.addEventListener('click', function () { window.scrollTo({ top: 0, behavior: 'smooth' }); });

    var reveal = document.getElementById('emailReveal');
    var copyBtn = document.getElementById('emailCopy');
    var revealed = false;
    function revealEmail() {
      if (revealed || !reveal) return;
      revealed = true;
      var addr = atob('Y2hhZXlvdW5n') + String.fromCharCode(64) + atob('c25zZWMubmV0');
      reveal.textContent = addr;
      reveal.setAttribute('href', 'mailto:' + addr);
      if (copyBtn) {
        var labelEn = copyBtn.getAttribute('data-en') || 'copy';
        copyBtn.addEventListener('click', function () {
          function fin() {
            copyBtn.textContent = '✓ copied';
            setTimeout(function () {
              var ko = copyBtn.getAttribute('data-ko'), cur = 'en';
              try { cur = localStorage.getItem('lang') || 'en'; } catch (e) {}
              copyBtn.textContent = cur === 'ko' && ko ? ko : labelEn;
            }, 1400);
          }
          function fallback() {
            var ta = document.createElement('textarea');
            ta.value = addr; ta.setAttribute('readonly', ''); ta.style.position = 'absolute'; ta.style.left = '-9999px';
            document.body.appendChild(ta); ta.select();
            try { document.execCommand('copy'); fin(); } catch (e) {}
            document.body.removeChild(ta);
          }
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(addr).then(fin, fallback);
          } else { fallback(); }
        });
      }
    }

    var t = document.getElementById('dockToggle');
    var pop = document.getElementById('contactPop');
    if (!t || !pop) return;
    function setOpen(o) {
      if (o) revealEmail();
      pop.classList.toggle('open', o);
      t.setAttribute('aria-expanded', o ? 'true' : 'false');
      pop.setAttribute('aria-hidden', o ? 'false' : 'true');
    }
    t.addEventListener('click', function (e) { e.stopPropagation(); setOpen(!pop.classList.contains('open')); });
    pop.addEventListener('click', function (e) { e.stopPropagation(); });
    document.addEventListener('click', function () { setOpen(false); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') setOpen(false); });
  })();
</script>
