---
import { Image } from 'astro:assets';
import selfie from '../assets/images/260418_selfie_CYL.jpg';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      try { if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark'); } catch (e) {}
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Chaeyoung Lee</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      try { if (sessionStorage.getItem('introSeen')) document.documentElement.classList.add('intro-seen'); } catch (e) {}
    </script>
    <style>
      :root {
        --bg: #fdfdfd; --bg-rgb: 253, 253, 253;
        --fg: #0d0d0d; --fg-rgb: 13, 13, 13;
        --surface: #f0f0f0; --muted: #555; --accent-hover: #262626;
        color-scheme: light;
      }
      html.dark {
        --bg: #0e0e10; --bg-rgb: 14, 14, 16;
        --fg: #f1f1f1; --fg-rgb: 241, 241, 241;
        --surface: #1c1c20; --muted: #9a9a9a; --accent-hover: #dcdcdc;
        color-scheme: dark;
      }
      html { background-color: var(--bg); }
      body { transition: background-color 0.25s ease, color 0.25s ease; }
      .theme-toggle {
        position: fixed; right: 1.5rem; bottom: 1.5rem; z-index: 60;
        width: 42px; height: 42px; display: inline-flex; align-items: center; justify-content: center;
        border-radius: 50%; border: 1px solid rgba(var(--fg-rgb), 0.14);
        background: var(--bg); color: var(--fg); cursor: pointer;
        box-shadow: 0 6px 20px rgba(var(--fg-rgb), 0.12);
        transition: background 0.25s ease, color 0.25s ease, transform 0.15s ease;
      }
      .theme-toggle:hover { transform: translateY(-2px); }
      .theme-toggle svg { width: 18px; height: 18px; }
      .theme-toggle .sun { display: none; }
      html.dark .theme-toggle .sun { display: inline-flex; }
      html.dark .theme-toggle .moon { display: none; }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        background-color: var(--bg);
      }

      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background-color: transparent;
        color: var(--fg);
        line-height: 1.5;
      }

      .container {
        max-width: 1300px;
        margin: 0 auto;
        padding: 0 2.5rem;
      }

      header {
        padding: 2rem 0;
      }

      nav {
        display: flex;
        justify-content: center;
        align-items: center;
      }

      .nav-container {
        display: inline-flex;
        align-items: center;
        gap: 2.5rem;
        background: rgba(var(--bg-rgb), 0.8);
        backdrop-filter: blur(10px);
        padding: 0.6rem 1.5rem;
        border-radius: 50px;
        border: 1px solid rgba(var(--fg-rgb), 0.05);
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        font-size: 0.95rem;
      }

      .logo-icon {
        width: 26px;
        height: 26px;
        background: var(--fg);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .logo-icon::before {
        content: 'G';
        color: var(--bg);
        font-weight: 700;
        font-size: 0.9rem;
      }

      .nav-links {
        display: flex;
        gap: 1.8rem;
        align-items: center;
      }

      .nav-links a {
        text-decoration: none;
        color: var(--fg);
        font-size: 0.85rem;
        font-weight: 500;
        opacity: 0.85;
        padding: 0.4rem 0.8rem;
        border-radius: 8px;
        transition: all 0.2s ease;
      }

      .nav-links a:hover {
        background: rgba(var(--fg-rgb), 0.05);
      }

      .nav-links a.active {
        background: var(--fg);
        color: var(--bg);
        opacity: 1;
        box-shadow: 0 4px 12px rgba(var(--fg-rgb), 0.2);
      }

      .language-selector {
        position: relative;
      }

      .language-btn {
        background: transparent;
        border: none;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--fg);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.3rem 0.6rem;
        border-radius: 6px;
        transition: background 0.2s ease;
      }

      .language-btn:hover {
        background: var(--surface);
      }

      .language-btn::after {
        content: '▾';
        font-size: 0.7rem;
        opacity: 0.6;
      }

      .language-dropdown {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        margin-top: 0.5rem;
        background: var(--bg);
        border: 1px solid rgba(var(--fg-rgb), 0.08);
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(var(--fg-rgb), 0.12);
        padding: 0.4rem;
        min-width: 110px;
        display: none;
        z-index: 100;
      }

      .language-dropdown.show {
        display: block;
      }

      .language-option {
        display: block;
        padding: 0.5rem 0.8rem;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.85rem;
        color: var(--fg);
        transition: background 0.2s ease;
      }

      .language-option:hover {
        background: var(--surface);
      }

      main {
        padding: 2rem 0 4rem;
      }

      .hero {
        display: grid;
        grid-template-columns: 55% 45%;
        gap: 2rem;
        align-items: center;
        min-height: 75vh;
      }

      .hero-content {
        padding-right: 1rem;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--surface);
        padding: 0.35rem 0.9rem;
        border-radius: 100px;
        font-size: 0.72rem;
        font-weight: 500;
        margin-bottom: 1.8rem;
        letter-spacing: 0.01em;
      }

      .badge::before {
        content: '';
        width: 8px;
        height: 8px;
        background: var(--fg);
        border-radius: 50%;
      }

      h1 {
        font-size: 4rem;
        font-weight: 700;
        line-height: 1.05;
        margin-bottom: 1.8rem;
        letter-spacing: -0.04em;
      }

      h1 span {
        font-style: italic;
        font-weight: 400;
        color: var(--muted);
        font-family: Georgia, 'Times New Roman', Times, serif;
      }

      .description {
        font-size: 0.98rem;
        color: var(--muted);
        margin-bottom: 2.2rem;
        max-width: 520px;
        line-height: 1.7;
      }

      .buttons {
        display: flex;
        gap: 1.2rem;
        margin-bottom: 5rem;
        align-items: center;
      }

      .btn {
        padding: 0.9rem 1.8rem;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        border: none;
        transition: all 0.2s ease;
      }

      .btn-primary {
        background: var(--fg);
        color: var(--bg);
        box-shadow: 0 8px 24px rgba(var(--fg-rgb), 0.2);
      }

      .btn-primary:hover {
        background: var(--accent-hover);
      }

      .btn-secondary {
        background: transparent;
        color: var(--fg);
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.9rem 1rem;
        font-weight: 500;
      }

      .btn-secondary::before {
        content: '▶';
        font-size: 0.6rem;
        width: 28px;
        height: 28px;
        border: 2px solid var(--fg);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .trusted-by {
        margin-top: 2rem;
      }

      .trusted-by p {
        font-size: 0.75rem;
        color: var(--muted);
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .logos {
        display: flex;
        gap: 2.2rem;
        align-items: center;
        opacity: 0.5;
      }

      .logo-item {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--muted);
        letter-spacing: 0.02em;
      }

      .hero-image {
        position: relative;
        height: 700px;
      }

      .image-container {
        position: absolute;
        right: -4rem;
        top: 0;
        width: 120%;
        height: 100%;
      }

      .gradient-bg {
        position: absolute;
        left: 10%;
        top: 40%;
        transform: translate(-50%, -50%);
        width: 65%;
        height: 70%;
        background: radial-gradient(ellipse at center, #ffd4d4 0%, #ffb3b3 50%, transparent 70%);
        border-radius: 50%;
        filter: blur(70px);
        opacity: 0.9;
      }

      .portrait-wrapper {
        position: relative;
        height: 100%;
        display: flex;
        justify-content: flex-end;
        align-items: flex-end;
      }

      .portrait-wrapper img {
        height: 100%;
        width: auto;
        max-width: 100%;
        object-fit: contain;
      }
      /* terminal background (tone-on-tone with var(--bg)) */
      .terminal-bg {
        position: fixed;
        inset: 0;
        z-index: -1;
        overflow: hidden;
        pointer-events: none;
        user-select: none;
        -webkit-mask-image: linear-gradient(to bottom, transparent 4%, #000 26%, #000 100%);
                mask-image: linear-gradient(to bottom, transparent 4%, #000 26%, #000 100%);
      }

      .terminal-stream {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        bottom: 42%;
        width: min(860px, 88vw);
        font-family: ui-monospace, 'SF Mono', 'Menlo', 'Consolas', monospace;
        font-size: 0.86rem;
        line-height: 1.75;
        color: rgba(var(--fg-rgb), 0.2);
        var(--bg)-space: pre-wrap;
        word-break: break-word;
      }

      .term-line { min-height: 1.75em; }
      .term-prompt { color: rgba(var(--fg-rgb), 0.32); }

      .cursor {
        display: inline-block;
        width: 0.6ch;
        background: rgba(var(--fg-rgb), 0.34);
        animation: term-blink 1.05s steps(1) infinite;
      }

      @keyframes term-blink { 50% { opacity: 0; } }

      @media (prefers-reduced-motion: reduce) {
        .cursor { animation: none; }
      }

      /* intro: handwritten signature (vara.js stroke animation), then reveal */
      .intro {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: var(--bg);
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
      }
      .intro-vara { width: min(90vw, 820px); padding-top: 0.4em; }
      .intro-vara svg { max-width: 100%; height: auto; overflow: visible !important; }
      .intro--out { animation: intro-fade 0.7s ease forwards; }
      @keyframes intro-fade { to { opacity: 0; visibility: hidden; } }
      html.intro-seen .intro { display: none; }

      /* floating dock bar (bottom-center) */
      .dock {
        --card-padding: 0.3rem;
        --card-radius: 16px;
        position: fixed;
        left: 50%;
        bottom: 1.5rem;
        transform: translateX(-50%);
        z-index: 50;
        display: flex;
        align-items: center;
        gap: 0.25rem;
        max-width: 36rem;
        width: auto;
        padding: var(--card-padding);
        background: var(--fg);
        border-radius: var(--card-radius);
        box-shadow: 0 10px 30px rgba(var(--fg-rgb), 0.18);
      }
      .dock-label {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.45rem 0.85rem;
        color: rgba(var(--bg-rgb), 0.82);
        font-size: 0.8rem;
        font-weight: 500;
        var(--bg)-space: nowrap;
      }
      .dock-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #34d399;
        animation: dock-pulse 2s ease-out infinite;
      }
      @keyframes dock-pulse {
        0% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.5); }
        70% { box-shadow: 0 0 0 7px rgba(52, 211, 153, 0); }
        100% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0); }
      }
      .dock-item {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.45rem 0.85rem;
        border-radius: calc(var(--card-radius) - var(--card-padding));
        color: var(--bg);
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 600;
        background: rgba(var(--bg-rgb), 0.08);
        transition: background 0.2s ease;
      }
      .dock-item:hover { background: rgba(var(--bg-rgb), 0.18); }

      @media (prefers-reduced-motion: reduce) {
        .dock-dot { animation: none; }
      }
    </style>
  </head>
  <body>
    <div class="intro" id="intro" aria-hidden="true">
      <div id="introVara" class="intro-vara"></div>
    </div>
    <div class="terminal-bg" aria-hidden="true">
      <div class="terminal-stream" id="termStream"></div>
    </div>
    <div class="container">
      <header>
        <nav>
          <div class="nav-container">
            <a href="/" class="logo" style="text-decoration: none; color: inherit;">
              <div class="logo-icon"></div>
            </a>
            <div class="nav-links">
              <a href="/" class="active">Home</a>
              <a href="/product">Product</a>
              <a href="/value">Value</a>
              <a href="/stories">Stories</a>
            </div>
          </div>
        </nav>
      </header>

      <main>
        <section class="hero">
          <div class="hero-content">
            <span class="badge">AI-powered workspace</span>
            <h1>Intelligent Technology<br />That <span>Simplifies Your World</span></h1>
            <p class="description">
              From your morning routine to your evening wind-down, intelligent systems seamlessly integrate into your daily flow—so you can focus on what truly matters.
            </p>
            <div class="buttons">
              <a href="/product" style="text-decoration: none;">
                <button class="btn btn-primary">Get early access</button>
              </a>
              <a href="/value" style="text-decoration: none;">
                <button class="btn btn-secondary">See how it works</button>
              </a>
            </div>
            <div class="trusted-by">
              <p>Trusted by teams at</p>
              <div class="logos">
                <span class="logo-item">TWITCH</span>
                <span class="logo-item">Stripe</span>
                <span class="logo-item">GitHub</span>
                <span class="logo-item">Vercel</span>
                <span class="logo-item">Slack</span>
              </div>
            </div>
          </div>
          <div class="hero-image">
            <div class="image-container">
              <div class="gradient-bg"></div>
              <div class="portrait-wrapper">
                <Image src={selfie} alt="Chaeyoung Lee" />
              </div>
            </div>
          </div>
        </section>
      </main>
    </div>
    <div class="dock" aria-label="Status and links">
      <span class="dock-label"><span class="dock-dot"></span>Security &amp; ML · SNSec-Lab</span>
      <a class="dock-item" href="https://github.com/alwaysY0ung" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
    </div>
    <script is:inline src="https://cdn.jsdelivr.net/npm/vara@1.4.1/src/vara.min.js"></script>
    <script>
      const stream = document.getElementById('termStream');
      if (stream) {
        const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
        const PROMPT = 'chaeyoung@SNSec-Lab:~$ ';
        const MAX = 40;
        const seq = [
          ['c', 'whoami'],
          ['o', 'chaeyoung — security & ML · SNSec-Lab'],
          ['c', 'python train.py --model transformer --epochs 50'],
          ['o', '[init] device=cuda:0  seed=42'],
          ['o', '[data] 128k samples  train/val = 0.9/0.1'],
          ['o', 'epoch 01/50  loss 2.4137  val 2.1090  lr 3e-4'],
          ['o', 'epoch 02/50  loss 1.9802  val 1.8553'],
          ['o', 'epoch 03/50  loss 1.7421  val 1.6890'],
          ['o', 'epoch 04/50  loss 1.5908  val 1.5402  (best)'],
          ['c', 'nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader'],
          ['o', '94 %'],
          ['c', 'git commit -am "ship it" && git push origin main'],
          ['o', 'To github.com:alwaysY0ung/chaeyoungnet.git'],
          ['o', '   main -> main'],
          ['c', 'curl -sI https://chaeyoung.net | head -1'],
          ['o', 'HTTP/2 200'],
          ['c', 'clear'],
        ];

        const cursor = document.createElement('span');
        cursor.className = 'cursor';
        cursor.textContent = ' ';
        const sleep = (ms) => new Promise((r) => setTimeout(r, ms));
        const trim = () => { while (stream.children.length > MAX) stream.removeChild(stream.firstChild); };

        function addLine(isCmd) {
          const el = document.createElement('div');
          el.className = 'term-line';
          if (isCmd) {
            const p = document.createElement('span');
            p.className = 'term-prompt';
            p.textContent = PROMPT;
            el.appendChild(p);
          }
          const span = document.createElement('span');
          el.appendChild(span);
          stream.appendChild(el);
          trim();
          return span;
        }

        async function typeLine(text, isCmd) {
          const span = addLine(isCmd);
          span.parentNode.appendChild(cursor);
          const base = isCmd ? 42 : 5;
          for (let i = 0; i < text.length; i++) {
            span.textContent += text[i];
            await sleep(base + Math.random() * (isCmd ? 55 : 7));
          }
        }

        let started = false;
        function startTerminal() {
          if (started) return;
          started = true;
          if (reduce) {
            seq.filter(([, t]) => t !== 'clear').forEach(([k, t]) => {
              addLine(k === 'c').textContent = t;
            });
            return;
          }
          (async () => {
            for (;;) {
              for (const [k, t] of seq) {
                await typeLine(t, k === 'c');
                await sleep(k === 'c' ? 480 : 110);
                if (t === 'clear') { await sleep(260); stream.innerHTML = ''; }
              }
              await sleep(1200);
            }
          })();
        }

        // start typing only after the intro handwriting finishes
        const intro = document.getElementById('intro');
        const introSeen = document.documentElement.classList.contains('intro-seen');

        function finishIntro() {
          if (intro) {
            intro.addEventListener('animationend', () => intro.remove(), { once: true });
            intro.classList.add('intro--out');
          }
          startTerminal();
        }

        if (reduce || !intro || introSeen) {
          if (intro) intro.remove();
          startTerminal();
        } else {
          try { sessionStorage.setItem('introSeen', '1'); } catch (e) {}
          const el = document.getElementById('introVara');
          let finished = false;
          const done = () => { if (finished) return; finished = true; finishIntro(); };
          if (typeof Vara !== 'undefined' && el) {
            try {
              const v = new Vara(
                '#introVara',
                'https://cdn.jsdelivr.net/gh/akzhy/vara@master/fonts/Parisienne/Parisienne.json',
                [{ text: 'Chaeyoung Lee' }],
                {
                  fontSize: Math.min(78, Math.round(window.innerWidth / 9)),
                  strokeWidth: 1.6,
                  color: document.documentElement.classList.contains('dark') ? '#f1f1f1' : '#0d0d0d',
                  duration: 1500,
                  textAlign: 'center',
                }
              );
              v.animationEnd(() => setTimeout(done, 650));
              setTimeout(done, 6000); // safety net if CDN/animation stalls
            } catch (e) {
              intro.remove();
              startTerminal();
            }
          } else {
            intro.remove();
            startTerminal();
          }
        }
      }
    </script>
    <button class="theme-toggle" id="themeToggle" type="button" aria-label="Toggle dark mode" title="Toggle theme">
      <svg class="moon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
    </button>
    <script is:inline>
      (function () {
        var b = document.getElementById('themeToggle');
        if (!b) return;
        b.addEventListener('click', function () {
          var dark = document.documentElement.classList.toggle('dark');
          try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {}
        });
      })();
    </script>
  </body>
</html>
