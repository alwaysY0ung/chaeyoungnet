    <div class="cmdk" id="cmdk" role="dialog" aria-modal="true" aria-label="Command palette">
      <div class="cmdk-panel">
        <input class="cmdk-input" type="text" placeholder="Search pages…  (⌘K)" autocomplete="off" spellcheck="false" aria-label="Search" />
        <ul class="cmdk-list" role="listbox"></ul>
      </div>
    </div>
    <script is:inline>
      (function () {
        var trigger = document.getElementById('cmdkTrigger');
        var overlay = document.getElementById('cmdk');
        if (!overlay) return;
        var input = overlay.querySelector('.cmdk-input');
        var list = overlay.querySelector('.cmdk-list');
        var items = [
          { label: 'Home', href: '/', hint: 'home' },
          { label: 'About', href: '/about' },
          { label: 'Papers', href: '/papers' },
          { label: 'Datasets', href: '/datasets' },
          { label: 'Patents', href: '/patents' },
          { label: 'Projects', href: '/projects' },
          { label: 'Services', href: '/services' },
          { label: 'Blog', href: '/blog' },
          { label: 'Dashboard', href: '/dashboard' },
          { label: 'GitHub', href: 'https://github.com/alwaysY0ung', hint: '↗', ext: true },
          { label: 'Toggle theme', action: 'theme', hint: '☾ / ☀' },
        ];
        var filtered = items.slice(), sel = 0;
        function render() {
          var q = input.value.trim().toLowerCase();
          filtered = items.filter(function (it) { return it.label.toLowerCase().indexOf(q) > -1; });
          if (sel >= filtered.length) sel = filtered.length - 1;
          if (sel < 0) sel = 0;
          list.innerHTML = '';
          if (!filtered.length) {
            var e = document.createElement('li');
            e.className = 'cmdk-empty';
            e.textContent = 'No results';
            list.appendChild(e);
            return;
          }
          filtered.forEach(function (it, i) {
            var li = document.createElement('li');
            li.className = 'cmdk-item';
            li.setAttribute('role', 'option');
            li.setAttribute('aria-selected', i === sel ? 'true' : 'false');
            var a = document.createElement('span'); a.textContent = it.label; li.appendChild(a);
            if (it.hint) { var h = document.createElement('span'); h.className = 'hint'; h.textContent = it.hint; li.appendChild(h); }
            li.addEventListener('click', function () { run(it); });
            li.addEventListener('mousemove', function () { sel = i; mark(); });
            list.appendChild(li);
          });
        }
        function mark() {
          var lis = list.querySelectorAll('.cmdk-item');
          for (var i = 0; i < lis.length; i++) lis[i].setAttribute('aria-selected', i === sel ? 'true' : 'false');
          if (lis[sel]) lis[sel].scrollIntoView({ block: 'nearest' });
        }
        function run(it) {
          if (!it) return;
          if (it.action === 'theme') {
            var dark = document.documentElement.classList.toggle('dark');
            try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {}
            close();
            return;
          }
          if (it.ext) { window.open(it.href, '_blank', 'noopener'); close(); return; }
          window.location.href = it.href;
        }
        function open() { overlay.classList.add('open'); input.value = ''; sel = 0; render(); setTimeout(function () { input.focus(); }, 0); }
        function close() { overlay.classList.remove('open'); }
        document.querySelectorAll('#cmdkTrigger, .cmdk-open').forEach(function (b) { b.addEventListener('click', open); });
        document.addEventListener('keydown', function (e) {
          if ((e.metaKey || e.ctrlKey) && (e.key === 'k' || e.key === 'K')) { e.preventDefault(); overlay.classList.contains('open') ? close() : open(); return; }
          if (!overlay.classList.contains('open')) return;
          if (e.key === 'Escape') { close(); }
          else if (e.key === 'ArrowDown') { e.preventDefault(); sel = Math.min(sel + 1, filtered.length - 1); mark(); }
          else if (e.key === 'ArrowUp') { e.preventDefault(); sel = Math.max(sel - 1, 0); mark(); }
          else if (e.key === 'Enter') { e.preventDefault(); run(filtered[sel]); }
        });
        input.addEventListener('input', function () { sel = 0; render(); });
        overlay.addEventListener('mousedown', function (e) { if (e.target === overlay) close(); });
      })();
    </script>
    <script is:inline>
      (function () {
        var burger = document.getElementById('navBurger');
        var links = document.getElementById('navLinks');
        if (!burger || !links) return;
        function setOpen(o) { links.classList.toggle('open', o); burger.setAttribute('aria-expanded', o ? 'true' : 'false'); }
        burger.addEventListener('click', function (e) { e.stopPropagation(); setOpen(!links.classList.contains('open')); });
        document.addEventListener('click', function (e) { if (!links.contains(e.target) && e.target !== burger && !burger.contains(e.target)) setOpen(false); });
        links.addEventListener('click', function (e) { if (e.target.tagName === 'A') setOpen(false); });
