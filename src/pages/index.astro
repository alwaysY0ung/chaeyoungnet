    <script is:inline>
      (function () {
        // scroll reveal
        var els = document.querySelectorAll('.reveal');
        if ('IntersectionObserver' in window && els.length) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
            });
          }, { threshold: 0.15, rootMargin: '0px 0px -8% 0px' });
          els.forEach(function (el, i) { el.style.transitionDelay = (i % 5) * 0.08 + 's'; io.observe(el); });
        } else {
          els.forEach(function (el) { el.classList.add('in'); });
        }
        // spam-safe email: base64-encoded parts, decoded ONLY on user interaction
        // (when the Contact window opens / on copy). Never present as plaintext in the
        // page source, never joined with a literal "@", and never assembled on load —
        // so crawlers that don't open the window never obtain the address.
        window.revealEmail = (function () {
          var done = false;
          return function () {
            if (done) return;
            done = true;
            var reveal = document.getElementById('emailReveal');
            var copyBtn = document.getElementById('emailCopy');
            if (!reveal) return;
            var addr = atob('Y2hhZXlvdW5n') + String.fromCharCode(64) + atob('c25zZWMubmV0');
            reveal.textContent = addr;
            reveal.setAttribute('href', 'mailto:' + addr);
            if (copyBtn) {
              var labelEn = copyBtn.getAttribute('data-en') || 'copy';
              copyBtn.addEventListener('click', function () {
                function fin() {
                  copyBtn.textContent = '✓ copied';
                  setTimeout(function () {
                    var ko = copyBtn.getAttribute('data-ko'), cur = 'en';
                    try { cur = localStorage.getItem('lang') || 'en'; } catch (e) {}
                    copyBtn.textContent = cur === 'ko' && ko ? ko : labelEn;
                  }, 1400);
                }
                function fallback() {
                  var t = document.createElement('textarea');
                  t.value = addr; t.setAttribute('readonly', ''); t.style.position = 'absolute'; t.style.left = '-9999px';
                  document.body.appendChild(t); t.select();
                  try { document.execCommand('copy'); fin(); } catch (e) {}
                  document.body.removeChild(t);
                }
                if (navigator.clipboard && navigator.clipboard.writeText) {
                  navigator.clipboard.writeText(addr).then(fin, fallback);
                } else { fallback(); }
              });
            }
          };
        })();
        // language switch (UI only for now)
        var opts = document.querySelectorAll('.lang-opt');
        function applyLang(lang) {
          document.querySelectorAll('[data-en]').forEach(function (el) {
            var t = lang === 'ko' ? el.getAttribute('data-ko') : el.getAttribute('data-en');
            if (t != null) el.textContent = t;
          });
          opts.forEach(function (x) { x.classList.toggle('active', x.dataset.lang === lang); });
        }
        var savedLang = 'en';
        try { savedLang = localStorage.getItem('lang') || 'en'; } catch (e) {}
        applyLang(savedLang);
        opts.forEach(function (o) {
          o.addEventListener('click', function () {
            try { localStorage.setItem('lang', o.dataset.lang); } catch (e) {}
            applyLang(o.dataset.lang);
          });
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var term = document.querySelector('.terminal-bg');
        var kra = document.querySelector('.home-sec'); // first section = Key Research Areas
        if (!term || !kra) return;
        var ticking = false;
        function update() {
          ticking = false;
          var vh = window.innerHeight || document.documentElement.clientHeight;
          var top = kra.getBoundingClientRect().top;
          // fully visible until KRA top reaches 70% of the viewport,
          // fully hidden by the time it reaches 30% — reverses on scroll up.
          var o = (top - vh * 0.3) / (vh * 0.4);
          o = Math.max(0, Math.min(1, o));
          term.style.opacity = o;
        }
        function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(update); } }
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
        update();
      })();
    </script>
