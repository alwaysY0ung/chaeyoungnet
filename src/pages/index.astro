---
import { Image } from 'astro:assets';
import selfie from '../assets/images/profile/260322_1557_CYL-Photoroom.png';
import BibList from '../components/BibList.astro';
import { selectedPublications } from '../data/research.js';

// Social / contact links (single source for the dock bar + contact popover).
// TODO: scholar / orcid / linkedin 의 url 을 실제 프로필 주소로 채우면
// 하단 바 아이콘과 Contact 팝오버에서 바로 클릭됩니다.
const socials = [
  { key: 'github', label: 'GitHub', url: 'https://github.com/alwaysY0ung' },
  { key: 'scholar', label: 'Google Scholar', url: 'https://scholar.google.com/citations?user=O9-EG6oAAAAJ' },
  { key: 'orcid', label: 'ORCID', url: 'https://orcid.org/0009-0006-8907-6504' },
  { key: 'linkedin', label: 'LinkedIn', url: 'https://www.linkedin.com/in/chaeyoung-lee-bb934b34a/' },
];
const ICONS = {
  github:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>',
  scholar:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>',
  orcid:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>',
  linkedin:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>',
};

// ── Home section content (snsec-style layout, but MY OWN content only). ──
// 빈 배열([])인 섹션은 자동으로 숨겨집니다. 항목을 추가하면 다시 나타납니다.
// 본문은 영어 전용. 섹션 라벨만 data-en/data-ko 로 번역됩니다.
const researchAreas = [
  { title: 'Core Tech', desc: 'Deep Learning, NLP' },
  { title: 'Security', desc: 'Data-driven Security, Intrusion Detection' },
  { title: 'Safety & Trust', desc: 'Adversarial Machine Learning, Automotive Security' },
  { title: 'Emerging Interests', desc: 'Data Poisoning, Machine Unlearning' },
];
// TODO: 본인이 실제로 참여 중인 협업만 추가하세요. (예: { title: '...', with: 'with ...' })
const collaborations = [];
// TODO: 본인 소식만 추가하세요.
// `href` is optional — only news with a related write-up get a "read on blog" link.
const news = [
  { date: 'Jun 3, 2026', text: 'Received the IEEE/IFIP DSN 2026 Student Travel Grant to attend the conference in Charlotte, NC.' },
  { date: 'Jun 3, 2026', text: 'Launched this personal website at chaeyoung.net (built June 1–3).' },
  { date: 'May 11, 2026', text: 'Registered the chaeyoung.net domain.' },
  { date: 'Apr 27, 2026', text: 'Our paper “DRIFT: Drift-Resilient Invariant-Feature Transformer for DGA Detection” (Chaeyoung Lee and Chaeri Jung, equal contribution) was accepted to IEEE/IFIP DSN’26.' },
];
// TODO: 블로그 글이 생기면 /blog 와 함께 갱신하세요.
const latestPosts = [];
// selectedPublications is imported from ../data/research.js (shared with /papers).
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      try { if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark'); } catch (e) {}
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Chaeyoung Lee</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      try { if (sessionStorage.getItem('introSeen')) document.documentElement.classList.add('intro-seen'); } catch (e) {}
    </script>
    <style>
      .cmdk-trigger {
        position: fixed; bottom: 1.5rem; right: 5.1rem; z-index: 60;
        width: 42px; height: 42px; display: inline-flex; align-items: center; justify-content: center;
        border-radius: 50%; border: 1px solid rgba(var(--fg-rgb), 0.14);
        background: var(--bg); color: var(--fg); cursor: pointer;
        box-shadow: 0 6px 20px rgba(var(--fg-rgb), 0.12);
        transition: background 0.25s ease, color 0.25s ease, transform 0.15s ease;
      }
      .cmdk-trigger:hover { transform: translateY(-2px); }
      .cmdk-trigger svg { width: 18px; height: 18px; }
      .cmdk { position: fixed; inset: 0; z-index: 200; display: none; align-items: flex-start; justify-content: center; background: rgba(0, 0, 0, 0.45); -webkit-backdrop-filter: blur(2px); backdrop-filter: blur(2px); padding-top: 15vh; }
      .cmdk.open { display: flex; }
      .cmdk-panel { width: min(520px, 92vw); background: var(--bg); border: 1px solid rgba(var(--fg-rgb), 0.12); border-radius: 14px; box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35); overflow: hidden; }
      .cmdk-input { width: 100%; box-sizing: border-box; border: none; outline: none; background: transparent; color: var(--fg); font-size: 1rem; font-family: inherit; padding: 1rem 1.1rem; border-bottom: 1px solid rgba(var(--fg-rgb), 0.08); }
      .cmdk-list { list-style: none; margin: 0; padding: 0.4rem; max-height: 320px; overflow-y: auto; }
      .cmdk-item { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; padding: 0.65rem 0.8rem; border-radius: 9px; cursor: pointer; font-size: 0.9rem; color: var(--fg); }
      .cmdk-item[aria-selected="true"] { background: rgba(var(--fg-rgb), 0.08); }
      .cmdk-item .hint { font-size: 0.72rem; color: var(--muted); }
      .cmdk-empty { padding: 0.9rem; color: var(--muted); font-size: 0.85rem; text-align: center; }
      :root {
        --bg: #fdfdfd; --bg-rgb: 253, 253, 253;
        --fg: #0d0d0d; --fg-rgb: 13, 13, 13;
        --surface: #f0f0f0; --muted: #555; --accent-hover: #262626;
        --photo-bg: #f2f1ef;
        --block: #333333; --block-fg: #fdfdfd;
        color-scheme: light;
      }
      html.dark {
        --bg: #1C1C1D; --bg-rgb: 28, 28, 29;
        --fg: #f1f1f1; --fg-rgb: 241, 241, 241;
        --surface: #26262a; --muted: #9a9a9a; --accent-hover: #dcdcdc;
        --photo-bg: #18181c;
        --block: #c9c9c9; --block-fg: #1C1C1D;
        color-scheme: dark;
      }
      html { background-color: var(--bg); }
      body { transition: background-color 0.25s ease, color 0.25s ease; }
      .top-right {
        position: fixed;
        top: 1.6rem;
        right: 2.5rem;
        z-index: 70;
        display: inline-flex;
        align-items: center;
        gap: 0.9rem;
      }
      .theme-toggle {
        width: 42px; height: 42px; display: inline-flex; align-items: center; justify-content: center;
        border-radius: 50%; border: 1px solid transparent;
        background: var(--fg); color: var(--bg); cursor: pointer;
        box-shadow: 0 6px 20px rgba(var(--fg-rgb), 0.18);
        transition: background 0.25s ease, color 0.25s ease, transform 0.15s ease;
      }
      .theme-toggle:hover { transform: translateY(-2px); }
      .theme-toggle svg { width: 18px; height: 18px; }
      .theme-toggle .sun { display: none; }
      html.dark .theme-toggle .sun { display: inline-flex; }
      html.dark .theme-toggle .moon { display: none; }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        background-color: var(--bg);
      }

      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background-color: transparent;
        color: var(--fg);
        line-height: 1.5;
      }

      .container {
        max-width: 1300px;
        margin: 0 auto;
        padding: 0 2.5rem;
      }

      header {
        padding: 1.5rem 0;
        position: sticky;
        top: 0;
        z-index: 100;
      }

      nav {
        display: flex;
        justify-content: center;
        align-items: center;
      }

      .nav-container {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 1.25rem;
        background: rgba(var(--bg-rgb), 0.8);
        backdrop-filter: blur(10px);
        padding: 0.6rem 1.5rem;
        border-radius: 50px;
        border: 1px solid rgba(var(--fg-rgb), 0.14);
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        font-size: 0.95rem;
      }

      .logo-icon {
        height: 26px;
        padding: 0 0.5rem;
        background: var(--block);
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .logo-icon::before {
        content: 'Chaeyoung Lee';
        color: var(--bg);
        font-weight: 700;
        font-size: 0.82rem;
        letter-spacing: 0.02em;
      }

      .nav-links {
        display: flex;
        gap: 0.5rem;
        align-items: center;
      }

      .nav-links a {
        text-decoration: none;
        color: var(--fg);
        font-size: 0.82rem;
        font-weight: 500;
        opacity: 0.82;
        padding: 0.38rem 0.6rem;
        border-radius: 8px;
        transition: all 0.2s ease;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        line-height: 1;
      }

      .nav-links a:hover {
        background: rgba(var(--fg-rgb), 0.10);
        opacity: 1;
      }

      .nav-links a.active {
        background: var(--block);
        color: var(--bg);
        opacity: 1;
        box-shadow: 0 4px 12px rgba(var(--fg-rgb), 0.2);
      }

      /* snsec-style nav: publications dropdown */
      .nav-group { position: relative; }
      .nav-group::after {
        content: '';
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        height: 0.6rem;
      }
      .nav-group-btn {
        background: transparent;
        border: none;
        cursor: pointer;
        color: var(--fg);
        font-family: inherit;
        font-size: 0.82rem;
        font-weight: 500;
        opacity: 0.82;
        padding: 0.38rem 0.6rem;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        white-space: nowrap;
        line-height: 1;
        transition: background 0.2s ease, opacity 0.2s ease;
      }
      .nav-group:hover .nav-group-btn { background: rgba(var(--fg-rgb), 0.10); opacity: 1; }
      .nav-group-menu {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        margin-top: 0.5rem;
        background: var(--bg);
        border: 1px solid rgba(var(--fg-rgb), 0.08);
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(var(--fg-rgb), 0.12);
        padding: 0.4rem;
        min-width: 140px;
        display: none;
        z-index: 100;
      }
      .nav-group:hover .nav-group-menu { display: block; }
      .nav-group-menu a {
        display: block;
        padding: 0.5rem 0.8rem;
        border-radius: 6px;
        font-size: 0.82rem;
        opacity: 0.9;
      }
      .nav-group-menu a:hover { background: var(--surface); opacity: 1; }

      .nav-login {
        border: 1px solid rgba(var(--fg-rgb), 0.2);
      }
      .nav-k {
        background: transparent;
        border: 1px solid rgba(var(--fg-rgb), 0.18);
        color: var(--fg);
        opacity: 0.82;
        font-family: inherit;
        font-size: 0.7rem;
        letter-spacing: 0.02em;
        padding: 0.28rem 0.5rem;
        border-radius: 6px;
        cursor: pointer;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        line-height: 1;
        margin-left: 0.75rem; /* wider gap than between nav items, like the logo group */
        transition: background 0.2s ease, color 0.2s ease;
      }
      .nav-k:hover { background: rgba(var(--fg-rgb), 0.10); opacity: 1; }
      .nav-k-ico { font-size: 0.72rem; opacity: 0.75; }

      .nav-burger {
        display: none;
        background: transparent;
        border: none;
        cursor: pointer;
        color: var(--fg);
        padding: 0.3rem;
        border-radius: 8px;
        align-items: center;
        justify-content: center;
      }
      .nav-burger:hover { background: rgba(var(--fg-rgb), 0.10); }

      @media (max-width: 900px) {
        .nav-container { gap: 0.75rem; }
        .nav-burger { display: inline-flex; }
        .nav-links {
          display: none;
          position: absolute;
          top: calc(100% + 0.5rem);
          right: 0;
          flex-direction: column;
          align-items: stretch;
          gap: 0.12rem;
          background: var(--bg);
          border: 1px solid rgba(var(--fg-rgb), 0.14);
          border-radius: 14px;
          box-shadow: 0 12px 40px rgba(var(--fg-rgb), 0.16);
          padding: 0.5rem;
          min-width: 210px;
          z-index: 120;
        }
        .nav-links.open { display: flex; }
        .nav-group { position: static; }
        .nav-group-btn { width: 100%; justify-content: flex-start; }
        .nav-group-menu {
          position: static;
          display: block;
          transform: none;
          margin: 0.1rem 0 0.2rem 0.7rem;
          box-shadow: none;
          border: none;
          padding: 0;
          min-width: 0;
        }
        .nav-links > a { width: 100%; }
        .nav-k { width: 100%; justify-content: flex-start; margin-top: 0.2rem; margin-left: 0; }
      }

      .language-selector {
        position: relative;
      }

      .language-btn {
        background: transparent;
        border: none;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--fg);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.3rem 0.6rem;
        border-radius: 6px;
        transition: background 0.2s ease;
      }

      .language-btn:hover {
        background: var(--surface);
      }

      .language-btn::after {
        content: '▾';
        font-size: 0.7rem;
        opacity: 0.6;
      }

      .language-dropdown {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        margin-top: 0.5rem;
        background: var(--bg);
        border: 1px solid rgba(var(--fg-rgb), 0.08);
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(var(--fg-rgb), 0.12);
        padding: 0.4rem;
        min-width: 110px;
        display: none;
        z-index: 100;
      }

      .language-dropdown.show {
        display: block;
      }

      .language-option {
        display: block;
        padding: 0.5rem 0.8rem;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.85rem;
        color: var(--fg);
        transition: background 0.2s ease;
      }

      .language-option:hover {
        background: var(--surface);
      }

      main {
        padding: 2rem 0 4rem;
      }

      .hero {
        display: grid;
        grid-template-columns: 55% 45%;
        gap: 2rem;
        align-items: center;
        min-height: 75vh;
      }

      .hero-content {
        padding-right: 1rem;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--surface);
        padding: 0.35rem 0.9rem;
        border-radius: 100px;
        font-size: 0.72rem;
        font-weight: 500;
        margin-bottom: 1.8rem;
        letter-spacing: 0.01em;
      }

      .badge::before {
        content: '';
        width: 8px;
        height: 8px;
        background: var(--block);
        border-radius: 50%;
      }

      h1 {
        font-size: 4rem;
        font-weight: 700;
        line-height: 1.05;
        margin-bottom: 1.8rem;
        letter-spacing: -0.04em;
      }

      h1 span {
        font-style: italic;
        font-weight: 400;
        color: var(--muted);
        font-family: Georgia, 'Times New Roman', Times, serif;
      }

      .description {
        font-size: 0.98rem;
        color: var(--muted);
        margin-bottom: 2.2rem;
        max-width: 520px;
        line-height: 1.7;
      }

      .buttons {
        display: flex;
        gap: 1.2rem;
        margin-bottom: 5rem;
        align-items: center;
      }

      .btn {
        padding: 0.9rem 1.8rem;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        border: none;
        transition: all 0.2s ease;
      }

      .btn-primary {
        background: var(--block);
        color: var(--bg);
        box-shadow: 0 8px 24px rgba(var(--fg-rgb), 0.2);
      }

      .btn-primary:hover {
        background: var(--accent-hover);
      }

      .btn-secondary {
        background: transparent;
        color: var(--fg);
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.9rem 1rem;
        font-weight: 500;
      }

      .btn-secondary::before {
        content: '▶';
        font-size: 0.6rem;
        width: 28px;
        height: 28px;
        border: 2px solid var(--fg);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .trusted-by {
        margin-top: 2rem;
      }

      .trusted-by p {
        font-size: 0.75rem;
        color: var(--muted);
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .logos {
        display: flex;
        gap: 2.2rem;
        align-items: center;
        opacity: 0.5;
      }

      .logo-item {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--muted);
        letter-spacing: 0.02em;
      }

      .hero-image {
        position: relative;
        height: 700px;
      }

      .hero-image::after {
        content: '';
        position: absolute;
        left: 8%;
        right: 8%;
        bottom: 0;
        height: 1px;
        background: linear-gradient(to right, transparent, rgba(var(--fg-rgb), 0.28), transparent);
        z-index: 2;
      }

      .image-container {
        position: absolute;
        right: 0;
        top: 0;
        width: 100%;
        height: 100%;
      }

      .gradient-bg {
        position: absolute;
        left: 10%;
        top: 40%;
        transform: translate(-40%, -30%);
        width: 115%;
        height: 70%;
        background: radial-gradient(ellipse at center, #ffd4d4 0%, #ffb3b3 50%, transparent 70%);
        border-radius: 50%;
        filter: blur(70px);
        opacity: 0.9;
      }

      .photo-bg {
        position: absolute;
        left: 50%;
        top: 0;
        transform: translateX(-50%);
        width: 88%;
        height: 100%;
        border-radius: 24px;
        background: var(--photo-bg);
        z-index: 0;
      }

      .portrait-wrapper {
        position: relative;
        z-index: 1;
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: flex-end;
      }

      .portrait-wrapper img {
        height: 85%;
        width: auto;
        max-width: 100%;
        object-fit: contain;
        object-position: bottom;
        border-radius: 18px;
        filter: brightness(1.12) contrast(0.92);
      }
      /* terminal background (tone-on-tone with var(--bg)) */
      .terminal-bg {
        position: fixed;
        inset: 0;
        z-index: -1;
        overflow: hidden;
        pointer-events: none;
        user-select: none;
        -webkit-mask-image: linear-gradient(to bottom, transparent 4%, #000 26%, #000 100%);
                mask-image: linear-gradient(to bottom, transparent 4%, #000 26%, #000 100%);
      }

      .terminal-stream {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        bottom: 42%;
        width: min(860px, 88vw);
        font-family: ui-monospace, 'SF Mono', 'Menlo', 'Consolas', monospace;
        font-size: 0.86rem;
        line-height: 1.75;
        color: rgba(var(--fg-rgb), 0.2);
        white-space: pre-wrap;
        word-break: break-word;
      }

      .term-line { min-height: 1.75em; }
      .term-prompt { color: rgba(var(--fg-rgb), 0.32); }

      .cursor {
        display: inline-block;
        width: 0.6ch;
        background: rgba(var(--fg-rgb), 0.34);
        animation: term-blink 1.05s steps(1) infinite;
      }

      @keyframes term-blink { 50% { opacity: 0; } }

      @media (prefers-reduced-motion: reduce) {
        .cursor { animation: none; }
      }

      /* intro: handwritten signature (vara.js stroke animation), then reveal */
      .intro {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: var(--bg);
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
      }
      .intro-vara { width: min(90vw, 820px); padding: 1.7em 0 0.7em; overflow: visible; }
      .intro-vara > * { overflow: visible !important; }
      .intro-vara svg { max-width: 100%; height: auto; overflow: visible !important; display: block; }
      .intro--out { animation: intro-fade 0.7s ease forwards; }
      @keyframes intro-fade { to { opacity: 0; visibility: hidden; } }
      html.intro-seen .intro { display: none; }

      /* floating dock bar (bottom-center) */
      .dock-wrap {
        position: fixed;
        left: 50%;
        bottom: 1.5rem;
        transform: translateX(-50%);
        z-index: 50;
      }
      .dock {
        --card-padding: 0.3rem;
        --card-radius: 16px;
        display: flex;
        align-items: center;
        gap: 0.2rem;
        width: auto;
        padding: var(--card-padding);
        background: var(--block);
        border-radius: var(--card-radius);
        box-shadow: 0 10px 30px rgba(var(--fg-rgb), 0.18);
      }
      .dock-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.45rem 0.85rem;
        background: transparent;
        border: none;
        cursor: pointer;
        color: rgba(var(--bg-rgb), 0.9);
        font-family: inherit;
        font-size: 0.8rem;
        font-weight: 600;
        white-space: nowrap;
        border-radius: calc(var(--card-radius) - var(--card-padding));
        transition: background 0.2s ease;
      }
      .dock-toggle:hover { background: rgba(var(--bg-rgb), 0.12); }
      .dock-caret { font-size: 0.62rem; opacity: 0.7; transition: transform 0.28s ease; }
      .dock-toggle[aria-expanded='true'] .dock-caret { transform: rotate(180deg); }
      .dock-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #34d399;
        animation: dock-pulse 2s ease-out infinite;
      }
      @keyframes dock-pulse {
        0% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.5); }
        70% { box-shadow: 0 0 0 7px rgba(52, 211, 153, 0); }
        100% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0); }
      }
      .dock-sep { width: 1px; height: 18px; margin: 0 0.15rem; background: rgba(var(--bg-rgb), 0.18); }
      .dock-item {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: calc(var(--card-radius) - var(--card-padding));
        color: var(--bg);
        text-decoration: none;
        background: transparent;
        transition: background 0.2s ease, transform 0.15s ease;
      }
      .dock-item svg { width: 16px; height: 16px; display: block; }
      .dock-item:hover { background: rgba(var(--bg-rgb), 0.14); transform: translateY(-1px); }
      .dock-item--todo { opacity: 0.4; cursor: default; }
      .dock-item--todo:hover { background: transparent; transform: none; }
      .dock-top { cursor: pointer; }
      .dock-top svg { fill: none; stroke: currentColor; }
      /* short attention shake (triggered from the about contact hint) */
      @keyframes dock-shake {
        10%, 90% { transform: translateX(-2px); }
        20%, 80% { transform: translateX(3px); }
        30%, 50%, 70% { transform: translateX(-6px); }
        40%, 60% { transform: translateX(6px); }
      }
      .dock.shake { animation: dock-shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97); }
      @media (prefers-reduced-motion: reduce) { .dock.shake { animation: none; } }

      /* contact popover — a macOS window that minimizes to / restores from the dock (⌘M feel) */
      .contact-pop {
        position: absolute;
        left: 50%;
        bottom: calc(100% + 1.6rem);
        width: min(440px, 92vw);
        opacity: 0;
        visibility: hidden;
        transform: translateX(-50%) translateY(30px) scale(0.55);
        transform-origin: bottom center;
        transition: opacity 0.24s ease, transform 0.36s cubic-bezier(0.2, 0.9, 0.25, 1.12), visibility 0s linear 0.36s;
      }
      .contact-pop.open {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0) scale(1);
        transition: opacity 0.2s ease, transform 0.36s cubic-bezier(0.2, 0.9, 0.25, 1.12), visibility 0s;
      }
      .contact-win {
        background: var(--bg);
        border: 1px solid rgba(var(--fg-rgb), 0.14);
        border-radius: 12px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.38);
        overflow: hidden;
      }
      .contact-head {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.6rem 0.85rem;
        background: rgba(var(--fg-rgb), 0.04);
        border-bottom: 1px solid rgba(var(--fg-rgb), 0.08);
      }
      .win-dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
      .win-dot--r { background: #ff5f57; } .win-dot--y { background: #febc2e; } .win-dot--g { background: #28c840; }
      .win-title { margin-left: 0.4rem; font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.74rem; color: var(--muted); }
      .contact-body { padding: 1.45rem 1.55rem 1.55rem; font-family: ui-monospace, 'SF Mono', Menlo, 'Consolas', monospace; }
      .contact-cmd { font-size: 0.84rem; color: rgba(var(--fg-rgb), 0.5); margin-bottom: 0.7rem; }
      .contact-cmd .term-prompt { color: rgba(var(--fg-rgb), 0.38); }
      .contact-row { display: flex; align-items: center; gap: 0.7rem; }
      .email-reveal { font-size: 1.06rem; font-weight: 600; color: var(--fg); text-decoration: none; word-break: break-all; }
      a.email-reveal:hover { text-decoration: underline; }
      .email-copy { margin-left: auto; flex: none; font-family: inherit; font-size: 0.72rem; padding: 0.32rem 0.62rem; border-radius: 6px; border: 1px solid rgba(var(--fg-rgb), 0.18); background: var(--block); color: var(--bg); cursor: pointer; transition: opacity 0.2s ease; }
      .email-copy:hover { opacity: 0.85; }
      .contact-foot { margin-top: 0.85rem; font-family: 'Inter', system-ui, sans-serif; font-size: 0.76rem; color: var(--muted); line-height: 1.55; }

      @media (prefers-reduced-motion: reduce) {
        .dock-dot { animation: none; }
        .contact-pop { transition: opacity 0.15s ease, visibility 0s; transform: translateX(-50%); }
        .contact-pop.open { transform: translateX(-50%); }
      }
      /* scroll reveal (kotei-style rise) */
      .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1); }
      .reveal.in { opacity: 1; transform: none; }

      /* about section */
      .about { max-width: 760px; margin: 0 auto; padding: 6rem 0 5rem; }
      .about-eyebrow { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.78rem; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 1rem; }
      .about-title { font-size: 2.4rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 1.2rem; }
      .about-lead { font-size: 1.15rem; line-height: 1.7; margin-bottom: 1rem; }
      .about-lead strong { font-weight: 600; }
      .about-body { font-size: 1rem; line-height: 1.8; color: var(--muted); margin-bottom: 1.6rem; }
      .about-block { margin: 2rem 0; }
      .about-h { font-size: 0.82rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.8rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(var(--fg-rgb), 0.1); }
      .about-ul { list-style: none; margin: 0; padding: 0; }
      .about-ul > li { position: relative; padding-left: 1.1rem; margin-bottom: 0.55rem; line-height: 1.65; font-size: 0.98rem; }
      .about-ul > li::before { content: '·'; position: absolute; left: 0.1rem; color: var(--muted); font-weight: 700; }
      .about-ul strong { font-weight: 600; }
      .about-ul a { color: var(--fg); text-decoration: underline; text-underline-offset: 2px; }
      .about-when { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.86rem; color: var(--muted); }
      .about-muted { color: var(--muted); }
      .about-sub { list-style: none; margin: 0.45rem 0 0.2rem; padding: 0; }
      .about-sub > li { position: relative; padding-left: 1.1rem; margin-bottom: 0.35rem; font-size: 0.92rem; line-height: 1.6; color: var(--muted); }
      .about-sub > li::before { content: '–'; position: absolute; left: 0.1rem; }

      /* home research sections (snsec-style) */
      .home-sec { max-width: 1000px; margin: 0 auto; padding: 3.2rem 0; }
      .sec-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 1.6rem; padding-bottom: 0.8rem; border-bottom: 1px solid rgba(var(--fg-rgb), 0.12); }
      .sec-title { font-size: 1.65rem; font-weight: 700; letter-spacing: -0.025em; }
      .sec-all { font-size: 0.85rem; color: var(--muted); text-decoration: none; white-space: nowrap; transition: color 0.2s ease; }
      .sec-all:hover { color: var(--fg); }
      .ra-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
      @media (min-width: 760px) { .ra-grid { grid-template-columns: 1fr 1fr; } }
      .ra-card { border: 1px solid rgba(var(--fg-rgb), 0.08); border-radius: 14px; padding: 1.3rem 1.4rem; background: var(--surface); transition: transform 0.2s ease, box-shadow 0.2s ease; }
      .ra-card:hover { transform: translateY(-3px); box-shadow: 0 14px 34px rgba(var(--fg-rgb), 0.08); }
      .ra-card h3 { font-size: 1.02rem; font-weight: 700; margin-bottom: 0.45rem; letter-spacing: -0.01em; }
      .ra-card p { color: var(--muted); font-size: 0.92rem; line-height: 1.6; }
      .collab-list { list-style: none; margin: 0; padding: 0; }
      .collab-list li { padding: 0.85rem 0; border-bottom: 1px solid rgba(var(--fg-rgb), 0.08); line-height: 1.5; }
      .collab-list li:last-child { border-bottom: none; }
      .collab-title { font-weight: 600; }
      .collab-with { color: var(--muted); font-size: 0.9rem; }
      .feed-list { list-style: none; margin: 0; padding: 0; }
      .feed-item { display: grid; grid-template-columns: 7.5rem 1fr; gap: 0.4rem 1.2rem; padding: 0.85rem 0; border-bottom: 1px solid rgba(var(--fg-rgb), 0.08); }
      .feed-item:last-child { border-bottom: none; }
      .feed-date { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.8rem; color: var(--muted); padding-top: 0.1rem; }
      .feed-text { line-height: 1.6; font-size: 0.96rem; }
      .feed-more { display: inline-block; margin-left: 0.5rem; font-size: 0.84rem; font-weight: 600; color: var(--link); text-decoration: none; white-space: nowrap; }
      .feed-more:hover { text-decoration: underline; text-underline-offset: 3px; }
      @media (max-width: 640px) { .feed-item { grid-template-columns: 1fr; gap: 0.2rem; } }
      .pub-sel-list { list-style: none; margin: 0; padding: 0; }
      .pub-sel { padding: 1.1rem 0; border-bottom: 1px solid rgba(var(--fg-rgb), 0.08); }
      .pub-sel:last-child { border-bottom: none; }
      .pub-sel-title { font-size: 1.02rem; font-weight: 700; line-height: 1.4; margin-bottom: 0.3rem; }
      .pub-sel-authors { color: var(--fg); font-size: 0.9rem; opacity: 0.85; }
      .pub-sel-venue { color: var(--muted); font-size: 0.88rem; font-style: italic; margin-top: 0.15rem; }
      .pub-sel-award { display: inline-block; margin-top: 0.5rem; font-size: 0.72rem; font-weight: 600; color: var(--fg); background: rgba(var(--fg-rgb), 0.08); border-radius: 100px; padding: 0.2rem 0.6rem; }
      .about-contact-hint { display: inline-block; font-size: 0.92rem; color: var(--muted); cursor: pointer; user-select: none; transition: color 0.2s ease; }
      .about-contact-hint:hover { color: var(--fg); }
      .about-contact-hint:hover strong { text-decoration: underline; }
      .about-contact-hint strong { color: var(--fg); font-weight: 600; }

      /* contact card (elevated surface, seyko-style) */
      .contact-card { display: flex; flex-direction: column; gap: 1.2rem; border-radius: 16px; background: var(--surface); border: 1px solid rgba(var(--fg-rgb), 0.06); box-shadow: 0 12px 34px rgba(var(--fg-rgb), 0.07); padding: 1.7rem; }
      .contact-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.4rem; }
      .contact-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; }
      .contact-actions { display: flex; flex-wrap: wrap; gap: 0.7rem; }
      .contact-btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.6rem 1rem; border-radius: 10px; font-size: 0.88rem; font-weight: 600; cursor: pointer; text-decoration: none; border: 1px solid rgba(var(--fg-rgb), 0.14); background: var(--bg); color: var(--fg); transition: transform 0.15s ease, background 0.2s ease; }
      .contact-btn.primary { background: var(--block); color: var(--bg); border-color: var(--block); }
      .contact-btn:hover { transform: translateY(-1px); }

      /* language switch (eng | kor) */
      .lang { display: inline-flex; align-items: center; gap: 0.35rem; }
      .lang-opt { background: transparent; border: none; cursor: pointer; font-family: inherit; font-size: 0.78rem; color: rgba(var(--fg-rgb), 0.4); padding: 0.2rem 0.12rem; transition: color 0.2s ease; }
      .lang-opt:hover { color: var(--fg); }
      .lang-opt.active { color: var(--fg); font-weight: 600; }
      .lang-sep { color: rgba(var(--fg-rgb), 0.25); font-size: 0.78rem; }

      @media (max-width: 900px) { .about-title { font-size: 1.9rem; } .about { padding: 4rem 0; } }
      @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }
    </style>
  </head>
  <body>
    <div class="intro" id="intro" aria-hidden="true">
      <div id="introVara" class="intro-vara"></div>
    </div>
    <div class="terminal-bg" aria-hidden="true">
      <div class="terminal-stream" id="termStream"></div>
    </div>
    <div class="container">
      <header>
        <nav>
          <div class="nav-container">
            <a href="/" class="logo" style="text-decoration: none; color: inherit;">
              <div class="logo-icon"></div>
            </a>
            <button class="nav-burger" id="navBurger" type="button" aria-label="Menu" aria-expanded="false">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
            </button>
            <div class="nav-links" id="navLinks">
              <a href="/about" data-en="about" data-ko="소개">about</a>
              <div class="nav-group">
                <button class="nav-group-btn" type="button" data-en="publications ▾" data-ko="출판물 ▾">publications ▾</button>
                <div class="nav-group-menu">
                  <a href="/papers" data-en="papers" data-ko="논문">papers</a>
                  <a href="/datasets" data-en="datasets" data-ko="데이터셋">datasets</a>
                  <a href="/patents" data-en="patents" data-ko="특허">patents</a>
                </div>
              </div>
              <a href="/projects" data-en="projects" data-ko="프로젝트">projects</a>
              <a href="/services" data-en="services" data-ko="활동">services</a>
              <a href="/blog" data-en="blog" data-ko="블로그">blog</a>
              <a href="/dashboard" data-en="dashboard" data-ko="대시보드">dashboard</a>
              <button class="nav-k cmdk-open" type="button" aria-label="Search (Ctrl/Cmd + K)"><span class="nav-k-ico">🔍</span> ctrl k</button>
            </div>
          </div>
        </nav>
      </header>

      <main>
        <section class="hero">
          <div class="hero-content">
            <span class="badge" data-en="Security × Machine Learning" data-ko="보안 × 머신러닝">Security × Machine Learning</span>
            <h1>Chaeyoung Lee<br /><span>Security &amp; ML researcher</span></h1>
            <p class="description" data-en="Fourth-year undergraduate in the Division of Artificial Intelligence Engineering (minoring in Big Data) at Sookmyung Women's University (2023–present), and currently an undergraduate researcher at SNSec Lab. I work on data-driven security with machine learning — building robust, explainable systems that detect and explain intrusions, from connected vehicles to evolving network threats." data-ko="숙명여자대학교 인공지능공학부(빅데이터 부전공) 학사 4학년에 재학 중이며(2023–현재), SNSec Lab에서 학부연구생으로 활동하고 있습니다. 머신러닝을 활용한 데이터 기반 보안을 연구하며, 커넥티드 카부터 끊임없이 진화하는 네트워크 위협까지 — 침입을 탐지하고 그 근거까지 설명하는, 견고하고 해석 가능한 시스템을 만듭니다.">
              Fourth-year undergraduate in the Division of Artificial Intelligence Engineering (minoring in Big Data) at Sookmyung Women's University (2023–present), and currently an undergraduate researcher at SNSec Lab. I work on data-driven security with machine learning — building robust, explainable systems that detect and explain intrusions, from connected vehicles to evolving network threats.
            </p>
            <div class="buttons">
              <a href="/papers" style="text-decoration: none;">
                <button class="btn btn-primary" data-en="Publications" data-ko="출판물">Publications</button>
              </a>
              <a href="/about" style="text-decoration: none;">
                <button class="btn btn-secondary" data-en="About me" data-ko="소개">About me</button>
              </a>
            </div>
          </div>
          <div class="hero-image">
            <div class="image-container">
              <div class="gradient-bg"></div>
              <!--<div class="photo-bg"></div>-->
              <div class="portrait-wrapper">
                <Image src={selfie} alt="Chaeyoung Lee" />
              </div>
            </div>
          </div>
        </section>

        <section class="home-sec reveal">
          <div class="sec-head">
            <h2 class="sec-title" data-en="Key Research Areas" data-ko="주요 연구 분야">Key Research Areas</h2>
          </div>
          <div class="ra-grid">
            {researchAreas.map((a) => (
              <article class="ra-card">
                <h3>{a.title}</h3>
                <p>{a.desc}</p>
              </article>
            ))}
          </div>
        </section>

        {collaborations.length > 0 && (
          <section class="home-sec reveal">
            <div class="sec-head">
              <h2 class="sec-title" data-en="Research & collaborations in progress" data-ko="진행 중인 연구·협업">Research &amp; collaborations in progress</h2>
            </div>
            <ul class="collab-list">
              {collaborations.map((c) => (
                <li><span class="collab-title">{c.title}</span> <span class="collab-with">{c.with}</span></li>
              ))}
            </ul>
          </section>
        )}

        {news.length > 0 && (
          <section class="home-sec reveal">
            <div class="sec-head">
              <h2 class="sec-title" data-en="News" data-ko="소식">News</h2>
            </div>
            <ul class="feed-list">
              {news.map((n) => (
                <li class="feed-item"><span class="feed-date">{n.date}</span><span class="feed-text">{n.text}{n.href && (<a class="feed-more" href={n.href} data-en="Read on blog →" data-ko="블로그에서 자세히 보기 →">Read on blog →</a>)}</span></li>
              ))}
            </ul>
          </section>
        )}

        {latestPosts.length > 0 && (
          <section class="home-sec reveal">
            <div class="sec-head">
              <h2 class="sec-title" data-en="Latest posts" data-ko="최근 글">Latest posts</h2>
              <a class="sec-all" href="/blog" data-en="see all →" data-ko="전체 보기 →">see all →</a>
            </div>
            <ul class="feed-list">
              {latestPosts.map((p) => (
                <li class="feed-item"><span class="feed-date">{p.date}</span><span class="feed-text">{p.title}</span></li>
              ))}
            </ul>
          </section>
        )}

        {selectedPublications.length > 0 && (
          <section class="home-sec reveal">
            <div class="sec-head">
              <h2 class="sec-title" data-en="Selected publications" data-ko="대표 출판물">Selected publications</h2>
              <a class="sec-all" href="/papers" data-en="see all →" data-ko="전체 보기 →">see all →</a>
            </div>
          <BibList items={selectedPublications} />
          </section>
        )}
      </main>
    </div>
    <div class="dock-wrap">
      <div class="contact-pop" id="contactPop" role="dialog" aria-label="Contact email" aria-hidden="true">
        <div class="contact-win">
          <div class="contact-head">
            <span class="win-dot win-dot--r"></span>
            <span class="win-dot win-dot--y"></span>
            <span class="win-dot win-dot--g"></span>
            <span class="win-title">contact — email</span>
          </div>
          <div class="contact-body">
            <p class="contact-cmd"><span class="term-prompt">~$ </span>echo&nbsp;$EMAIL</p>
            <div class="contact-row">
              <a class="email-reveal" id="emailReveal" href="#" rel="noopener">…</a>
              <button class="email-copy" id="emailCopy" type="button" aria-label="Copy email" data-en="copy" data-ko="복사">copy</button>
            </div>
