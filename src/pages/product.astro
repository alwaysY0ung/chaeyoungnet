<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      try { if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark'); } catch (e) {}
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Product - Chaeyoung Lee</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #fdfdfd; --bg-rgb: 253, 253, 253;
        --fg: #0d0d0d; --fg-rgb: 13, 13, 13;
        --surface: #f0f0f0; --muted: #555; --accent-hover: #262626;
        color-scheme: light;
      }
      html.dark {
        --bg: #0e0e10; --bg-rgb: 14, 14, 16;
        --fg: #f1f1f1; --fg-rgb: 241, 241, 241;
        --surface: #1c1c20; --muted: #9a9a9a; --accent-hover: #dcdcdc;
        color-scheme: dark;
      }
      html { background-color: var(--bg); }
      body { transition: background-color 0.25s ease, color 0.25s ease; }
      .theme-toggle {
        position: fixed; right: 1.5rem; bottom: 1.5rem; z-index: 60;
        width: 42px; height: 42px; display: inline-flex; align-items: center; justify-content: center;
        border-radius: 50%; border: 1px solid rgba(var(--fg-rgb), 0.14);
        background: var(--bg); color: var(--fg); cursor: pointer;
        box-shadow: 0 6px 20px rgba(var(--fg-rgb), 0.12);
        transition: background 0.25s ease, color 0.25s ease, transform 0.15s ease;
      }
      .theme-toggle:hover { transform: translateY(-2px); }
      .theme-toggle svg { width: 18px; height: 18px; }
      .theme-toggle .sun { display: none; }
      html.dark .theme-toggle .sun { display: inline-flex; }
      html.dark .theme-toggle .moon { display: none; }

      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Inter', system-ui, -apple-system, sans-serif; background-color: var(--bg); color: var(--fg); line-height: 1.5; }
      .container { max-width: 1300px; margin: 0 auto; padding: 0 2.5rem; }
      header { padding: 2rem 0; }
      nav { display: flex; justify-content: center; align-items: center; }
      .nav-container { display: inline-flex; align-items: center; gap: 2.5rem; background: rgba(var(--bg-rgb), 0.8); backdrop-filter: blur(10px); padding: 0.6rem 1.5rem; border-radius: 50px; border: 1px solid rgba(var(--fg-rgb), 0.05); }
      .logo { display: flex; align-items: center; gap: 0.5rem; font-weight: 600; font-size: 0.95rem; }
      .logo-icon { width: 26px; height: 26px; background: var(--fg); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
      .logo-icon::before { content: 'G'; color: var(--bg); font-weight: 700; font-size: 0.9rem; }
      .nav-links { display: flex; gap: 1.8rem; align-items: center; }
      .nav-links a { text-decoration: none; color: var(--fg); font-size: 0.85rem; font-weight: 500; opacity: 0.85; padding: 0.4rem 0.8rem; border-radius: 8px; transition: all 0.2s ease; }
      .nav-links a:hover { background: rgba(var(--fg-rgb), 0.05); }
      .nav-links a.active { background: var(--fg); color: var(--bg); opacity: 1; box-shadow: 0 4px 12px rgba(var(--fg-rgb), 0.2); }
      .language-selector { position: relative; }
      .language-btn { background: transparent; border: none; font-size: 0.85rem; font-weight: 500; color: var(--fg); cursor: pointer; display: flex; align-items: center; gap: 0.4rem; padding: 0.3rem 0.6rem; border-radius: 6px; transition: background 0.2s ease; }
      .language-btn:hover { background: var(--surface); }
      .language-btn::after { content: '▾'; font-size: 0.7rem; opacity: 0.6; }
      .language-dropdown { position: absolute; top: 100%; left: 50%; transform: translateX(-50%); margin-top: 0.5rem; background: var(--bg); border: 1px solid rgba(var(--fg-rgb), 0.08); border-radius: 12px; box-shadow: 0 8px 30px rgba(var(--fg-rgb), 0.12); padding: 0.4rem; min-width: 110px; display: none; z-index: 100; }
      .language-dropdown.show { display: block; }
      .language-option { display: block; padding: 0.5rem 0.8rem; border-radius: 6px; cursor: pointer; font-size: 0.85rem; color: var(--fg); transition: background 0.2s ease; }
      .language-option:hover { background: var(--surface); }
      main { padding: 2rem 0 4rem; }
      .hero { padding: 4rem 0; }
      .badge { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--surface); padding: 0.35rem 0.9rem; border-radius: 100px; font-size: 0.72rem; font-weight: 500; margin-bottom: 1.8rem; letter-spacing: 0.01em; }
      .badge::before { content: ''; width: 8px; height: 8px; background: var(--fg); border-radius: 50%; }
      h1 { font-size: 4rem; font-weight: 700; line-height: 1.05; margin-bottom: 1.8rem; letter-spacing: -0.04em; }
      h1 span { font-style: italic; font-weight: 400; color: var(--muted); font-family: Georgia, 'Times New Roman', Times, serif; }
      .description { font-size: 0.98rem; color: var(--muted); margin-bottom: 3rem; max-width: 520px; line-height: 1.7; }
      .features { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 3rem; }
      .feature-card { background: var(--bg); padding: 2rem; border-radius: 16px; border: 1px solid rgba(var(--fg-rgb), 0.05); transition: transform 0.3s ease; }
      .feature-card:hover { transform: translateY(-4px); }
      .feature-icon { width: 48px; height: 48px; background: var(--surface); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; font-size: 1.5rem; }
      .feature-title { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.75rem; }
      .feature-desc { color: var(--muted); font-size: 0.95rem; line-height: 1.6; }
      .buttons { display: flex; gap: 1.2rem; align-items: center; }
      .btn { padding: 0.9rem 1.8rem; border-radius: 12px; font-size: 0.9rem; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s ease; }
      .btn-primary { background: var(--fg); color: var(--bg); box-shadow: 0 8px 24px rgba(var(--fg-rgb), 0.2); }
      .btn-primary:hover { background: var(--accent-hover); }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <nav>
          <div class="nav-container">
            <a href="/" class="logo" style="text-decoration: none; color: inherit;">
              <div class="logo-icon"></div>
            </a>
            <div class="nav-links">
              <a href="/">Home</a>
              <a href="/product" class="active">Product</a>
              <a href="/value">Value</a>
              <a href="/stories">Stories</a>
            </div>
          </div>
        </nav>
      </header>
      <main>
        <section class="hero">
          <span class="badge">Product Features</span>
          <h1>Powerful Product<br />Features</h1>
          <p class="description">Our product integrates cutting-edge AI technology to provide you with comprehensive solutions.</p>
          <div class="features">
            <div class="feature-card">
              <div class="feature-icon">⚡</div>
              <h3 class="feature-title">Lightning Fast</h3>
              <p class="feature-desc">Millisecond-level response speed, boosting your team's productivity by 10x.</p>
            </div>
            <div class="feature-card">
              <div class="feature-icon">🔒</div>
              <h3 class="feature-title">Secure & Reliable</h3>
              <p class="feature-desc">Enterprise-grade security standards, protecting your data safety.</p>
            </div>
            <div class="feature-card">
              <div class="feature-icon">🎯</div>
              <h3 class="feature-title">Precision AI</h3>
              <p class="feature-desc">AI-driven intelligent analysis helps you make better decisions.</p>
            </div>
          </div>
          <div style="margin-top: 3rem;">
            <div class="buttons">
              <a href="/value" style="text-decoration: none;">
                <button class="btn btn-primary">Get Started</button>
              </a>
            </div>
          </div>
        </section>
      </main>
    </div>
    <button class="theme-toggle" id="themeToggle" type="button" aria-label="Toggle dark mode" title="Toggle theme">
      <svg class="moon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
    </button>
    <script is:inline>
      (function () {
        var b = document.getElementById('themeToggle');
        if (!b) return;
        b.addEventListener('click', function () {
          var dark = document.documentElement.classList.toggle('dark');
          try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {}
        });
      })();
    </script>
  </body>
</html>
