---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      try { if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark'); } catch (e) {}
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Stories - Chaeyoung Lee</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      .cmdk-trigger {
        position: fixed; bottom: 1.5rem; right: 5.1rem; z-index: 60;
        width: 42px; height: 42px; display: inline-flex; align-items: center; justify-content: center;
        border-radius: 50%; border: 1px solid rgba(var(--fg-rgb), 0.14);
        background: var(--bg); color: var(--fg); cursor: pointer;
        box-shadow: 0 6px 20px rgba(var(--fg-rgb), 0.12);
        transition: background 0.25s ease, color 0.25s ease, transform 0.15s ease;
      }
      .cmdk-trigger:hover { transform: translateY(-2px); }
      .cmdk-trigger svg { width: 18px; height: 18px; }
      .cmdk { position: fixed; inset: 0; z-index: 200; display: none; align-items: flex-start; justify-content: center; background: rgba(0, 0, 0, 0.45); -webkit-backdrop-filter: blur(2px); backdrop-filter: blur(2px); padding-top: 15vh; }
      .cmdk.open { display: flex; }
      .cmdk-panel { width: min(520px, 92vw); background: var(--bg); border: 1px solid rgba(var(--fg-rgb), 0.12); border-radius: 14px; box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35); overflow: hidden; }
      .cmdk-input { width: 100%; box-sizing: border-box; border: none; outline: none; background: transparent; color: var(--fg); font-size: 1rem; font-family: inherit; padding: 1rem 1.1rem; border-bottom: 1px solid rgba(var(--fg-rgb), 0.08); }
      .cmdk-list { list-style: none; margin: 0; padding: 0.4rem; max-height: 320px; overflow-y: auto; }
      .cmdk-item { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; padding: 0.65rem 0.8rem; border-radius: 9px; cursor: pointer; font-size: 0.9rem; color: var(--fg); }
      .cmdk-item[aria-selected="true"] { background: rgba(var(--fg-rgb), 0.08); }
      .cmdk-item .hint { font-size: 0.72rem; color: var(--muted); }
      .cmdk-empty { padding: 0.9rem; color: var(--muted); font-size: 0.85rem; text-align: center; }
      :root {
        --bg: #fdfdfd; --bg-rgb: 253, 253, 253;
        --fg: #0d0d0d; --fg-rgb: 13, 13, 13;
        --surface: #f0f0f0; --muted: #555; --accent-hover: #262626;
        color-scheme: light;
      }
      html.dark {
        --bg: #0e0e10; --bg-rgb: 14, 14, 16;
        --fg: #f1f1f1; --fg-rgb: 241, 241, 241;
        --surface: #1c1c20; --muted: #9a9a9a; --accent-hover: #dcdcdc;
        color-scheme: dark;
      }
      html { background-color: var(--bg); }
      body { transition: background-color 0.25s ease, color 0.25s ease; }
      .theme-toggle {
        position: fixed; right: 1.5rem; bottom: 1.5rem; z-index: 60;
        width: 42px; height: 42px; display: inline-flex; align-items: center; justify-content: center;
        border-radius: 50%; border: 1px solid rgba(var(--fg-rgb), 0.14);
        background: var(--bg); color: var(--fg); cursor: pointer;
        box-shadow: 0 6px 20px rgba(var(--fg-rgb), 0.12);
        transition: background 0.25s ease, color 0.25s ease, transform 0.15s ease;
      }
      .theme-toggle:hover { transform: translateY(-2px); }
      .theme-toggle svg { width: 18px; height: 18px; }
      .theme-toggle .sun { display: none; }
      html.dark .theme-toggle .sun { display: inline-flex; }
      html.dark .theme-toggle .moon { display: none; }

      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Inter', system-ui, -apple-system, sans-serif; background-color: var(--bg); color: var(--fg); line-height: 1.5; }
      .container { max-width: 1300px; margin: 0 auto; padding: 0 2.5rem; }
      header { padding: 2rem 0; }
      nav { display: flex; justify-content: center; align-items: center; }
      .nav-container { display: inline-flex; align-items: center; gap: 2.5rem; background: rgba(var(--bg-rgb), 0.8); backdrop-filter: blur(10px); padding: 0.6rem 1.5rem; border-radius: 50px; border: 1px solid rgba(var(--fg-rgb), 0.05); }
      .logo { display: flex; align-items: center; gap: 0.5rem; font-weight: 600; font-size: 0.95rem; }
      .logo-icon { width: 26px; height: 26px; background: var(--fg); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
      .logo-icon::before { content: 'G'; color: var(--bg); font-weight: 700; font-size: 0.9rem; }
      .nav-links { display: flex; gap: 1.8rem; align-items: center; }
      .nav-links a { text-decoration: none; color: var(--fg); font-size: 0.85rem; font-weight: 500; opacity: 0.85; padding: 0.4rem 0.8rem; border-radius: 8px; transition: all 0.2s ease; }
      .nav-links a:hover { background: rgba(var(--fg-rgb), 0.05); }
      .nav-links a.active { background: var(--fg); color: var(--bg); opacity: 1; box-shadow: 0 4px 12px rgba(var(--fg-rgb), 0.2); }
      .language-selector { position: relative; }
      .language-btn { background: transparent; border: none; font-size: 0.85rem; font-weight: 500; color: var(--fg); cursor: pointer; display: flex; align-items: center; gap: 0.4rem; padding: 0.3rem 0.6rem; border-radius: 6px; transition: background 0.2s ease; }
      .language-btn:hover { background: var(--surface); }
      .language-btn::after { content: '▾'; font-size: 0.7rem; opacity: 0.6; }
      .language-dropdown { position: absolute; top: 100%; left: 50%; transform: translateX(-50%); margin-top: 0.5rem; background: var(--bg); border: 1px solid rgba(var(--fg-rgb), 0.08); border-radius: 12px; box-shadow: 0 8px 30px rgba(var(--fg-rgb), 0.12); padding: 0.4rem; min-width: 110px; display: none; z-index: 100; }
      .language-dropdown.show { display: block; }
      .language-option { display: block; padding: 0.5rem 0.8rem; border-radius: 6px; cursor: pointer; font-size: 0.85rem; color: var(--fg); transition: background 0.2s ease; }
      .language-option:hover { background: var(--surface); }
      main { padding: 2rem 0 4rem; }
      .hero { padding: 4rem 0; }
      .badge { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--surface); padding: 0.35rem 0.9rem; border-radius: 100px; font-size: 0.72rem; font-weight: 500; margin-bottom: 1.8rem; letter-spacing: 0.01em; }
      .badge::before { content: ''; width: 8px; height: 8px; background: var(--fg); border-radius: 50%; }
      h1 { font-size: 4rem; font-weight: 700; line-height: 1.05; margin-bottom: 1.8rem; letter-spacing: -0.04em; }
      h1 span { font-style: italic; font-weight: 400; color: var(--muted); font-family: Georgia, 'Times New Roman', Times, serif; }
      .description { font-size: 0.98rem; color: var(--muted); margin-bottom: 3rem; max-width: 520px; line-height: 1.7; }
      .stories { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; margin-top: 3rem; }
      .story-card { background: var(--bg); padding: 2.5rem; border-radius: 16px; border: 1px solid rgba(var(--fg-rgb), 0.05); transition: transform 0.3s ease; }
      .story-card:hover { transform: translateY(-4px); }
      .story-quote { font-size: 1.1rem; line-height: 1.7; color: var(--muted); margin-bottom: 1.5rem; font-style: italic; }
      .story-author { display: flex; align-items: center; gap: 1rem; }
      .author-avatar { width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 600; font-size: 1.1rem; }
      .author-info { display: flex; flex-direction: column; }
      .author-name { font-weight: 600; font-size: 0.95rem; }
      .author-role { color: var(--muted); font-size: 0.85rem; }
      .buttons { display: flex; gap: 1.2rem; align-items: center; }
      .btn { padding: 0.9rem 1.8rem; border-radius: 12px; font-size: 0.9rem; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s ease; }
      .btn-primary { background: var(--fg); color: var(--bg); box-shadow: 0 8px 24px rgba(var(--fg-rgb), 0.2); }
      .btn-primary:hover { background: var(--accent-hover); }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <nav>
          <div class="nav-container">
            <a href="/" class="logo" style="text-decoration: none; color: inherit;">
              <div class="logo-icon"></div>
            </a>
            <div class="nav-links">
              <a href="/">Home</a>
              <a href="/product">Product</a>
              <a href="/value">Value</a>
              <a href="/stories" class="active">Stories</a>
            </div>
          </div>
        </nav>
      </header>
      <main>
        <section class="hero">
          <span class="badge">Customer Stories</span>
          <h1>Hear What<br /><span>They Say</span></h1>
          <p class="description">Real feedback from customers around the world, witnessing the value we create together.</p>
          <div class="stories">
            <div class="story-card">
              <p class="story-quote">"This product completely transformed the way we work. Productivity increased 10x and team morale is higher than ever."</p>
              <div class="story-author">
                <div class="author-avatar">L</div>
                <div class="author-info">
                  <span class="author-name">Li Ming</span>
                  <span class="author-role">Tech Company CEO</span>
                </div>
              </div>
            </div>
            <div class="story-card">
              <p class="story-quote">"AI-driven analysis makes our decisions much more precise. ROI exceeded our expectations."</p>
              <div class="story-author">
                <div class="author-avatar">Z</div>
                <div class="author-info">
                  <span class="author-name">Zhang Wei</span>
                  <span class="author-role">Investment Director</span>
                </div>
              </div>
            </div>
            <div class="story-card">
              <p class="story-quote">"The 24/7 AI assistant elevated our customer service to the next level. Customer satisfaction improved dramatically."</p>
              <div class="story-author">
                <div class="author-avatar">W</div>
                <div class="author-info">
                  <span class="author-name">Wang Fang</span>
                  <span class="author-role">Customer Service Director</span>
                </div>
              </div>
            </div>
            <div class="story-card">
              <p class="story-quote">"The continuous learning feature is amazing. Every day we feel the product getting better."</p>
              <div class="story-author">
                <div class="author-avatar">C</div>
                <div class="author-info">
                  <span class="author-name">Chen Qiang</span>
                  <span class="author-role">Product Manager</span>
                </div>
              </div>
            </div>
          </div>
          <div style="margin-top: 3rem;">
            <div class="buttons">
              <a href="/value" style="text-decoration: none;">
                <button class="btn btn-primary">Share Your Story</button>
              </a>
            </div>
          </div>
        </section>
      </main>
    </div>
    <button class="theme-toggle" id="themeToggle" type="button" aria-label="Toggle dark mode" title="Toggle theme">
      <svg class="moon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
    </button>
    <script is:inline>
      (function () {
        var b = document.getElementById('themeToggle');
        if (!b) return;
        b.addEventListener('click', function () {
          var dark = document.documentElement.classList.toggle('dark');
          try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {}
        });
      })();
    </script>
    <button class="cmdk-trigger" id="cmdkTrigger" type="button" aria-label="Search (Cmd/Ctrl + K)" title="Search (⌘K)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
    </button>
    <div class="cmdk" id="cmdk" role="dialog" aria-modal="true" aria-label="Command palette">
      <div class="cmdk-panel">
        <input class="cmdk-input" type="text" placeholder="Search pages…  (⌘K)" autocomplete="off" spellcheck="false" aria-label="Search" />
        <ul class="cmdk-list" role="listbox"></ul>
      </div>
    </div>
    <script is:inline>
      (function () {
        var trigger = document.getElementById('cmdkTrigger');
        var overlay = document.getElementById('cmdk');
        if (!overlay) return;
        var input = overlay.querySelector('.cmdk-input');
        var list = overlay.querySelector('.cmdk-list');
        var items = [
          { label: 'Home', href: '/', hint: 'home' },
          { label: 'Product', href: '/product' },
          { label: 'Value', href: '/value' },
          { label: 'Stories', href: '/stories' },
          { label: 'GitHub', href: 'https://github.com/alwaysY0ung', hint: '↗', ext: true },
          { label: 'Toggle theme', action: 'theme', hint: '☾ / ☀' },
        ];
        var filtered = items.slice(), sel = 0;
        function render() {
          var q = input.value.trim().toLowerCase();
          filtered = items.filter(function (it) { return it.label.toLowerCase().indexOf(q) > -1; });
          if (sel >= filtered.length) sel = filtered.length - 1;
          if (sel < 0) sel = 0;
          list.innerHTML = '';
          if (!filtered.length) {
            var e = document.createElement('li');
            e.className = 'cmdk-empty';
            e.textContent = 'No results';
            list.appendChild(e);
            return;
          }
          filtered.forEach(function (it, i) {
            var li = document.createElement('li');
            li.className = 'cmdk-item';
            li.setAttribute('role', 'option');
            li.setAttribute('aria-selected', i === sel ? 'true' : 'false');
            var a = document.createElement('span'); a.textContent = it.label; li.appendChild(a);
            if (it.hint) { var h = document.createElement('span'); h.className = 'hint'; h.textContent = it.hint; li.appendChild(h); }
            li.addEventListener('click', function () { run(it); });
            li.addEventListener('mousemove', function () { sel = i; mark(); });
            list.appendChild(li);
          });
        }
        function mark() {
          var lis = list.querySelectorAll('.cmdk-item');
          for (var i = 0; i < lis.length; i++) lis[i].setAttribute('aria-selected', i === sel ? 'true' : 'false');
          if (lis[sel]) lis[sel].scrollIntoView({ block: 'nearest' });
        }
        function run(it) {
          if (!it) return;
          if (it.action === 'theme') {
            var dark = document.documentElement.classList.toggle('dark');
            try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {}
            close();
            return;
          }
          if (it.ext) { window.open(it.href, '_blank', 'noopener'); close(); return; }
          window.location.href = it.href;
        }
        function open() { overlay.classList.add('open'); input.value = ''; sel = 0; render(); setTimeout(function () { input.focus(); }, 0); }
        function close() { overlay.classList.remove('open'); }
        if (trigger) trigger.addEventListener('click', open);
        document.addEventListener('keydown', function (e) {
          if ((e.metaKey || e.ctrlKey) && (e.key === 'k' || e.key === 'K')) { e.preventDefault(); overlay.classList.contains('open') ? close() : open(); return; }
          if (!overlay.classList.contains('open')) return;
          if (e.key === 'Escape') { close(); }
          else if (e.key === 'ArrowDown') { e.preventDefault(); sel = Math.min(sel + 1, filtered.length - 1); mark(); }
          else if (e.key === 'ArrowUp') { e.preventDefault(); sel = Math.max(sel - 1, 0); mark(); }
          else if (e.key === 'Enter') { e.preventDefault(); run(filtered[sel]); }
        });
        input.addEventListener('input', function () { sel = 0; render(); });
        overlay.addEventListener('mousedown', function (e) { if (e.target === overlay) close(); });
      })();
    </script>
  </body>
</html>
