---
import SiteLayout from '../layouts/SiteLayout.astro';

const GH_USER = 'alwaysY0ung';
---
<SiteLayout title="Dashboard · Chaeyoung Lee" active="dashboard">
  <section class="page-wrap">
    <h1 class="page-h1 reveal" data-en="Dashboard" data-ko="대시보드">Dashboard</h1>
    <p class="page-lead reveal" data-en="Activity at a glance — GitHub contributions." data-ko="활동 현황 한눈에 보기 — GitHub 기여.">Activity at a glance — GitHub contributions.</p>

    <div class="dash-card reveal">
      <div class="dash-card-head">
        <h2>GitHub contributions</h2>
        <a href={`https://github.com/${GH_USER}`} target="_blank" rel="noopener noreferrer">@{GH_USER} ↗</a>
      </div>
      <img id="ghChart" class="dash-graph" alt="GitHub contribution graph" loading="lazy" />
    </div>

    <p class="page-note reveal" data-en="※ Graph is rendered via an external service (ghchart)." data-ko="※ 그래프는 외부 서비스(ghchart)로 렌더링됩니다.">※ Graph is rendered via an external service (ghchart).</p>
  </section>
</SiteLayout>

<style>
  .dash-card { border: 1px solid rgba(var(--fg-rgb), 0.1); border-radius: 16px; background: var(--surface); padding: 1.4rem 1.6rem 1.6rem; max-width: 900px; margin-bottom: 1.6rem; }
  .dash-card-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.1rem; flex-wrap: wrap; gap: 0.5rem; }
  .dash-card-head h2 { font-size: 1.1rem; font-weight: 700; }
  .dash-card-head a { font-size: 0.84rem; color: var(--muted); text-decoration: none; }
  .dash-card-head a:hover { color: var(--fg); }
  .dash-graph { width: 100%; height: auto; display: block; filter: saturate(1.2) contrast(1.06); }
</style>

<script is:inline define:vars={{ GH_USER }}>
  (function () {
    var img = document.getElementById('ghChart');
    if (img) img.src = 'https://ghchart.rshah.org/f0808f/' + GH_USER + '?' + Date.now();
  })();
</script>
