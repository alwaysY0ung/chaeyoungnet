---
// Shared chrome (head, nav, theme toggle, command palette, footer) for
// the publication sub-pages. Keeps them visually consistent with the
// landing page without duplicating the markup on every page.
import ContactDock from '../components/ContactDock.astro';
const { title = 'Chaeyoung Lee', active = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      try { if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark'); } catch (e) {}
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg: #fdfdfd; --bg-rgb: 253, 253, 253;
        --fg: #0d0d0d; --fg-rgb: 13, 13, 13;
        --surface: #f0f0f0; --muted: #555; --accent-hover: #262626;
        --block: #333333;
        --link: #2563eb;
        color-scheme: light;
      }
      html.dark {
        --bg: #1C1C1D; --bg-rgb: 28, 28, 29;
        --fg: #f1f1f1; --fg-rgb: 241, 241, 241;
        --surface: #26262a; --muted: #9a9a9a; --accent-hover: #dcdcdc;
        --block: #c9c9c9;
        --link: #6ea8fe;
        color-scheme: dark;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { background-color: var(--bg); }
      body { font-family: 'Inter', system-ui, -apple-system, sans-serif; color: var(--fg); line-height: 1.5; transition: background-color 0.25s ease, color 0.25s ease; }
      .container { max-width: 1300px; margin: 0 auto; padding: 0 2.5rem; }
      header { padding: 1.5rem 0; position: sticky; top: 0; z-index: 100; }
      nav { display: flex; justify-content: center; align-items: center; }
      .nav-container { position: relative; display: inline-flex; align-items: center; gap: 1.25rem; background: rgba(var(--bg-rgb), 0.8); backdrop-filter: blur(10px); padding: 0.6rem 1.5rem; border-radius: 50px; border: 1px solid rgba(var(--fg-rgb), 0.14); }
      .logo { display: flex; align-items: center; gap: 0.5rem; font-weight: 600; font-size: 0.95rem; }
      /* Outlined (not filled black) on sub-pages — home isn't the current page here.
         Matches the .nav-k "ctrl k" outline: transparent bg + same border color. */
      .logo-icon { height: 26px; padding: 0 0.5rem; background: transparent; border: 1px solid rgba(var(--fg-rgb), 0.18); border-radius: 7px; display: flex; align-items: center; justify-content: center; transition: background 0.2s ease; }
      .logo:hover .logo-icon { background: rgba(var(--fg-rgb), 0.06); }
      .logo-icon::before { content: 'Chaeyoung Lee'; color: var(--fg); font-weight: 700; font-size: 0.82rem; letter-spacing: 0.02em; }
      .nav-links { display: flex; gap: 0.5rem; align-items: center; }
      .nav-links a { text-decoration: none; color: var(--fg); font-size: 0.82rem; font-weight: 500; opacity: 0.82; padding: 0.38rem 0.6rem; border-radius: 8px; transition: all 0.2s ease; white-space: nowrap; display: inline-flex; align-items: center; line-height: 1; }
      .nav-links a:hover { background: rgba(var(--fg-rgb), 0.10); opacity: 1; }
      .nav-links a.active { background: var(--block); color: var(--bg); opacity: 1; box-shadow: 0 4px 12px rgba(var(--fg-rgb), 0.2); }
      .nav-group { position: relative; }
      .nav-group::after { content: ''; position: absolute; top: 100%; left: 0; right: 0; height: 0.6rem; }
      .nav-group-btn { background: transparent; border: none; cursor: pointer; color: var(--fg); font-family: inherit; font-size: 0.82rem; font-weight: 500; opacity: 0.82; padding: 0.38rem 0.6rem; border-radius: 8px; display: inline-flex; align-items: center; gap: 0.25rem; white-space: nowrap; line-height: 1; transition: background 0.2s ease, opacity 0.2s ease; }
      .nav-group:hover .nav-group-btn, .nav-group-btn.active { background: rgba(var(--fg-rgb), 0.10); opacity: 1; }
      .nav-group-menu { position: absolute; top: 100%; left: 50%; transform: translateX(-50%); margin-top: 0.5rem; background: var(--bg); border: 1px solid rgba(var(--fg-rgb), 0.08); border-radius: 12px; box-shadow: 0 8px 30px rgba(var(--fg-rgb), 0.12); padding: 0.4rem; min-width: 140px; display: none; z-index: 100; }
      @media (hover: hover) and (pointer: fine) { .nav-group:hover .nav-group-menu { display: block; } }
      .nav-group-btn .nav-group-caret { display: inline-block; transition: transform 0.2s ease; }
      .nav-group.open .nav-group-btn .nav-group-caret { transform: rotate(180deg); }
      @media (hover: hover) and (pointer: fine) { .nav-group:hover .nav-group-caret { transform: rotate(180deg); } }
      .nav-group-menu a { display: block; padding: 0.5rem 0.8rem; border-radius: 6px; font-size: 0.82rem; opacity: 0.9; }
      .nav-group-menu a:hover { background: var(--surface); opacity: 1; }
      .nav-group-menu a.active { background: var(--block); color: var(--bg); opacity: 1; }
      .nav-k { background: transparent; border: 1px solid rgba(var(--fg-rgb), 0.18); color: var(--fg); opacity: 0.82; font-family: inherit; font-size: 0.7rem; letter-spacing: 0.02em; padding: 0.28rem 0.5rem; border-radius: 6px; cursor: pointer; white-space: nowrap; display: inline-flex; align-items: center; gap: 0.3rem; line-height: 1; margin-left: 0.75rem; transition: background 0.2s ease, opacity 0.2s ease; }
      .nav-k:hover { background: rgba(var(--fg-rgb), 0.10); opacity: 1; }
      .nav-k-ico { font-size: 0.72rem; opacity: 0.75; }
      .nav-burger { display: none; background: transparent; border: none; cursor: pointer; color: var(--fg); padding: 0.3rem; border-radius: 8px; align-items: center; justify-content: center; }
      .nav-burger:hover { background: rgba(var(--fg-rgb), 0.10); }
      .nav-mobile-extra { display: none; }
      @media (max-width: 900px) {
        /* Full-width sticky bar: logo left, hamburger pinned far right. */
        .nav-container { gap: 0.75rem; width: 100%; justify-content: space-between; border-radius: 16px; }
        .nav-burger { display: inline-flex; order: 2; }
        .logo { order: 1; }
        /* eng|kor + theme toggle move into the menu instead of floating at the corner. */
        .top-right { display: none; }
        .nav-mobile-extra { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-top: 0.45rem; padding-top: 0.6rem; border-top: 1px solid rgba(var(--fg-rgb), 0.12); }
        .nav-mobile-extra .theme-toggle { width: 34px; height: 34px; box-shadow: none; }
        .nav-links { display: none; position: absolute; top: calc(100% + 0.5rem); right: 0; flex-direction: column; align-items: stretch; gap: 0.12rem; background: var(--bg); border: 1px solid rgba(var(--fg-rgb), 0.14); border-radius: 14px; box-shadow: 0 12px 40px rgba(var(--fg-rgb), 0.16); padding: 0.5rem; min-width: 210px; z-index: 120; }
        .nav-links.open { display: flex; }
        .nav-group { position: static; }
        .nav-group-btn { width: 100%; justify-content: flex-start; }
        .nav-group-menu { position: static; display: none; transform: none; margin: 0.1rem 0 0.2rem 0.7rem; box-shadow: none; border: none; padding: 0; min-width: 0; }
        .nav-group.open .nav-group-menu { display: block; }
        .nav-group.open .nav-group-btn { background: rgba(var(--fg-rgb), 0.10); opacity: 1; }
        .nav-links > a { width: 100%; }
        .nav-k { width: 100%; justify-content: flex-start; margin-top: 0.2rem; margin-left: 0; }
      }
      .top-right { position: fixed; top: 1.6rem; right: 2.5rem; z-index: 70; display: inline-flex; align-items: center; gap: 0.9rem; }
      .theme-toggle { width: 42px; height: 42px; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; border: 1px solid transparent; background: var(--fg); color: var(--bg); cursor: pointer; box-shadow: 0 6px 20px rgba(var(--fg-rgb), 0.18); transition: background 0.25s ease, color 0.25s ease, transform 0.15s ease; }
      .theme-toggle:hover { transform: translateY(-2px); }
      .theme-toggle svg { width: 18px; height: 18px; }
      .theme-toggle .sun { display: none; }
      html.dark .theme-toggle .sun { display: inline-flex; }
      html.dark .theme-toggle .moon { display: none; }
      .lang { display: inline-flex; align-items: center; gap: 0.35rem; }
      .lang-opt { background: transparent; border: none; cursor: pointer; font-family: inherit; font-size: 0.78rem; color: rgba(var(--fg-rgb), 0.4); padding: 0.2rem 0.12rem; transition: color 0.2s ease; }
      .lang-opt:hover { color: var(--fg); }
      .lang-opt.active { color: var(--fg); font-weight: 600; }
      .lang-sep { color: rgba(var(--fg-rgb), 0.25); font-size: 0.78rem; }
      .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1); }
      .reveal.in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }
      /* simple content pages (services / blog / dashboard) */
      .page-wrap { padding: 1.5rem 0 4rem; }
      .page-h1 { font-size: clamp(2.6rem, 7vw, 5rem); font-weight: 800; letter-spacing: -0.04em; line-height: 1; margin-bottom: 1.2rem; }
      .page-lead { font-size: 1.05rem; color: var(--muted); line-height: 1.7; max-width: 640px; margin-bottom: 2.5rem; text-wrap: balance; }
      .page-note { color: var(--muted); font-size: 0.95rem; line-height: 1.8; }
      /* command palette */
      .cmdk { position: fixed; inset: 0; z-index: 200; display: none; align-items: flex-start; justify-content: center; background: rgba(0, 0, 0, 0.45); -webkit-backdrop-filter: blur(2px); backdrop-filter: blur(2px); padding-top: 15vh; }
      .cmdk.open { display: flex; }
      .cmdk-panel { width: min(520px, 92vw); background: var(--bg); border: 1px solid rgba(var(--fg-rgb), 0.12); border-radius: 14px; box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35); overflow: hidden; }
      .cmdk-input { width: 100%; box-sizing: border-box; border: none; outline: none; background: transparent; color: var(--fg); font-size: 1rem; font-family: inherit; padding: 1rem 1.1rem; border-bottom: 1px solid rgba(var(--fg-rgb), 0.08); }
      .cmdk-list { list-style: none; margin: 0; padding: 0.4rem; max-height: 320px; overflow-y: auto; }
      .cmdk-item { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; padding: 0.65rem 0.8rem; border-radius: 9px; cursor: pointer; font-size: 0.9rem; color: var(--fg); }
      .cmdk-item[aria-selected="true"] { background: rgba(var(--fg-rgb), 0.08); }
      .cmdk-item .hint { font-size: 0.72rem; color: var(--muted); }
      .cmdk-empty { padding: 0.9rem; color: var(--muted); font-size: 0.85rem; text-align: center; }
      /* footer */
      .site-foot { border-top: 1px solid rgba(var(--fg-rgb), 0.08); margin-top: 4rem; }
      .site-foot .container { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; padding-top: 2rem; padding-bottom: 6rem; }
      .site-foot p { font-size: 0.8rem; color: var(--muted); }
      .site-foot a { color: var(--muted); font-size: 0.8rem; text-decoration: none; }
      .site-foot a:hover { color: var(--fg); }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <nav>
          <div class="nav-container">
            <a href="/" class="logo" style="text-decoration: none; color: inherit;">
              <div class="logo-icon"></div>
            </a>
            <button class="nav-burger" id="navBurger" type="button" aria-label="Menu" aria-expanded="false">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
            </button>
            <div class="nav-links" id="navLinks">
              <a href="/about" class={active === 'about' ? 'active' : ''} data-en="about" data-ko="소개">about</a>
              <div class="nav-group">
                <button class={`nav-group-btn${['papers','datasets','patents'].includes(active) ? ' active' : ''}`} type="button" aria-haspopup="true" aria-expanded="false"><span data-en="publications" data-ko="출판물">publications</span><span class="nav-group-caret" aria-hidden="true">▾</span></button>
                <div class="nav-group-menu">
                  <a href="/papers" class={active === 'papers' ? 'active' : ''} data-en="papers" data-ko="논문">papers</a>
                  <a href="/datasets" class={active === 'datasets' ? 'active' : ''} data-en="datasets" data-ko="데이터셋">datasets</a>
                  <a href="/patents" class={active === 'patents' ? 'active' : ''} data-en="patents" data-ko="특허">patents</a>
                </div>
              </div>
              <a href="/projects" class={active === 'projects' ? 'active' : ''} data-en="projects" data-ko="프로젝트">projects</a>
              <a href="/services" class={active === 'services' ? 'active' : ''} data-en="services" data-ko="활동">services</a>
              <a href="/blog" class={active === 'blog' ? 'active' : ''} data-en="blog" data-ko="블로그">blog</a>
              <a href="/dashboard" class={active === 'dashboard' ? 'active' : ''} data-en="dashboard" data-ko="대시보드">dashboard</a>
              <button class="nav-k cmdk-open" type="button" aria-label="Search (Ctrl/Cmd + K)"><span class="nav-k-ico">🔍</span> ctrl k</button>
              <div class="nav-mobile-extra">
                <span class="lang" aria-label="Language">
                  <button class="lang-opt active" type="button" data-lang="en">eng</button>
                  <span class="lang-sep">|</span>
                  <button class="lang-opt" type="button" data-lang="ko" title="한국어 버전 준비 중">kor</button>
                </span>
                <button class="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle theme">
                  <svg class="moon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                  <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
                </button>
              </div>
            </div>
          </div>
        </nav>
      </header>

      <main>
        <slot />
      </main>
    </div>

    <footer class="site-foot">
      <div class="container">
        <p>© <span id="footYear">2026</span> Chaeyoung Lee · Security &amp; ML · SNSec-Lab</p>
        <a href="https://github.com/alwaysY0ung" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
      </div>
    </footer>

    <ContactDock />

    <div class="top-right">
      <span class="lang" aria-label="Language">
        <button class="lang-opt active" type="button" data-lang="en">eng</button>
        <span class="lang-sep">|</span>
        <button class="lang-opt" type="button" data-lang="ko" title="한국어 버전 준비 중">kor</button>
      </span>
      <button class="theme-toggle" id="themeToggle" type="button" aria-label="Toggle dark mode" title="Toggle theme">
        <svg class="moon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
      </button>
    </div>

    <div class="cmdk" id="cmdk" role="dialog" aria-modal="true" aria-label="Command palette">
      <div class="cmdk-panel">
        <input class="cmdk-input" type="text" placeholder="Search pages…  (⌘K)" autocomplete="off" spellcheck="false" aria-label="Search" />
        <ul class="cmdk-list" role="listbox"></ul>
      </div>
    </div>

    <script is:inline>
      (function () {
        document.querySelectorAll('.theme-toggle').forEach(function (b) {
          b.addEventListener('click', function () {
            var dark = document.documentElement.classList.toggle('dark');
            try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {}
          });
        });
        var burger = document.getElementById('navBurger');
        var links = document.getElementById('navLinks');
        if (burger && links) {
          function setOpen(o) { links.classList.toggle('open', o); burger.setAttribute('aria-expanded', o ? 'true' : 'false'); }
          burger.addEventListener('click', function (e) { e.stopPropagation(); setOpen(!links.classList.contains('open')); });
          document.addEventListener('click', function (e) { if (!links.contains(e.target) && e.target !== burger && !burger.contains(e.target)) setOpen(false); });
          links.addEventListener('click', function (e) { if (e.target.tagName === 'A') setOpen(false); });
        }
        // Tap to expand/collapse the publications sub-menu (mobile accordion).
        document.querySelectorAll('.nav-group-btn').forEach(function (btn) {
          btn.addEventListener('click', function (e) {
            if (!window.matchMedia('(max-width: 900px)').matches) return; // desktop opens on hover
            e.stopPropagation();
            var group = btn.closest('.nav-group');
            if (!group) return;
            var open = group.classList.toggle('open');
            btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          });
        });
        var y = document.getElementById('footYear'); // keep year fresh without Date in build
        // language switch + reveal
        var els = document.querySelectorAll('.reveal');
        if ('IntersectionObserver' in window && els.length) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
          }, { threshold: 0.15, rootMargin: '0px 0px -8% 0px' });
          els.forEach(function (el, i) { el.style.transitionDelay = (i % 6) * 0.06 + 's'; io.observe(el); });
        } else { els.forEach(function (el) { el.classList.add('in'); }); }
        var opts = document.querySelectorAll('.lang-opt');
        function applyLang(lang) {
          document.querySelectorAll('[data-en]').forEach(function (el) {
            var t = lang === 'ko' ? el.getAttribute('data-ko') : el.getAttribute('data-en');
            if (t != null) el.textContent = t;
          });
          opts.forEach(function (x) { x.classList.toggle('active', x.dataset.lang === lang); });
        }
        var savedLang = 'en';
        try { savedLang = localStorage.getItem('lang') || 'en'; } catch (e) {}
        applyLang(savedLang);
        opts.forEach(function (o) { o.addEventListener('click', function () { try { localStorage.setItem('lang', o.dataset.lang); } catch (e) {} applyLang(o.dataset.lang); }); });
      })();
    </script>
    <script is:inline>
      (function () {
        var overlay = document.getElementById('cmdk');
        if (!overlay) return;
        var input = overlay.querySelector('.cmdk-input');
        var list = overlay.querySelector('.cmdk-list');
        var items = [
          { label: 'Home', href: '/', hint: 'home' },
          { label: 'About', href: '/about' },
          { label: 'Papers', href: '/papers' },
          { label: 'Datasets', href: '/datasets' },
          { label: 'Patents', href: '/patents' },
          { label: 'Projects', href: '/projects' },
          { label: 'Services', href: '/services' },
          { label: 'Blog', href: '/blog' },
          { label: 'Dashboard', href: '/dashboard' },
          { label: 'GitHub', href: 'https://github.com/alwaysY0ung', hint: '↗', ext: true },
          { label: 'Toggle theme', action: 'theme', hint: '☾ / ☀' },
        ];
        var filtered = items.slice(), sel = 0;
        function render() {
          var q = input.value.trim().toLowerCase();
          filtered = items.filter(function (it) { return it.label.toLowerCase().indexOf(q) > -1; });
          if (sel >= filtered.length) sel = filtered.length - 1;
          if (sel < 0) sel = 0;
          list.innerHTML = '';
          if (!filtered.length) { var e = document.createElement('li'); e.className = 'cmdk-empty'; e.textContent = 'No results'; list.appendChild(e); return; }
          filtered.forEach(function (it, i) {
            var li = document.createElement('li'); li.className = 'cmdk-item'; li.setAttribute('role', 'option'); li.setAttribute('aria-selected', i === sel ? 'true' : 'false');
            var a = document.createElement('span'); a.textContent = it.label; li.appendChild(a);
            if (it.hint) { var h = document.createElement('span'); h.className = 'hint'; h.textContent = it.hint; li.appendChild(h); }
            li.addEventListener('click', function () { run(it); });
            li.addEventListener('mousemove', function () { sel = i; mark(); });
            list.appendChild(li);
          });
        }
        function mark() { var lis = list.querySelectorAll('.cmdk-item'); for (var i = 0; i < lis.length; i++) lis[i].setAttribute('aria-selected', i === sel ? 'true' : 'false'); if (lis[sel]) lis[sel].scrollIntoView({ block: 'nearest' }); }
        function run(it) {
          if (!it) return;
          if (it.action === 'theme') { var dark = document.documentElement.classList.toggle('dark'); try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {} close(); return; }
          if (it.ext) { window.open(it.href, '_blank', 'noopener'); close(); return; }
          window.location.href = it.href;
        }
        function open() { overlay.classList.add('open'); input.value = ''; sel = 0; render(); setTimeout(function () { input.focus(); }, 0); }
        function close() { overlay.classList.remove('open'); }
        document.querySelectorAll('.cmdk-open').forEach(function (b) { b.addEventListener('click', open); });
        document.addEventListener('keydown', function (e) {
          if ((e.metaKey || e.ctrlKey) && (e.key === 'k' || e.key === 'K')) { e.preventDefault(); overlay.classList.contains('open') ? close() : open(); return; }
          if (!overlay.classList.contains('open')) return;
          if (e.key === 'Escape') { close(); }
          else if (e.key === 'ArrowDown') { e.preventDefault(); sel = Math.min(sel + 1, filtered.length - 1); mark(); }
          else if (e.key === 'ArrowUp') { e.preventDefault(); sel = Math.max(sel - 1, 0); mark(); }
          else if (e.key === 'Enter') { e.preventDefault(); run(filtered[sel]); }
        });
        input.addEventListener('input', function () { sel = 0; render(); });
        overlay.addEventListener('mousedown', function (e) { if (e.target === overlay) close(); });
      })();
    </script>
  </body>
</html>
